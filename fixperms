    (0o644, "Read & Write for Owner, Read-Only for Everyone Else",
     "Only the owner can edit, everyone else can view",
     "Configuration files, documents, web content"),
    (0o640, "Read & Write for Owner, Read-Only for Group, Blocked for Others",
     "Owner can edit, group can view, outsiders blocked",
