#!/usr/bin/env python3
"""
Permission Manager
Inspect and set file/folder permissions and ownership with human-readable options.
Designed for users who don't know Linux permission numbers.
"""

import os
import sys
import stat
import pwd
import grp
import subprocess
from pathlib import Path
from collections import defaultdict


class Colors:
    """ANSI color codes for terminal output"""
    HEADER = '\033[95m'
    OKBLUE = '\033[94m'
    OKCYAN = '\033[96m'
    OKGREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    DIM = '\033[2m'
    UNDERLINE = '\033[4m'


# Human-readable permission presets
# Each entry: (octal, friendly_name, description, recommended_for)
PERMISSION_PRESETS = [
    (0o777, "Full Access for Everyone",
     "Anyone can read, write, and run files",
     "Shared folders where everyone needs full control"),
    (0o775, "Full for Owner & Group, Read & Run for Others",
