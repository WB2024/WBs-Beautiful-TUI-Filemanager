    (0o750, "Full for Owner, Read & Run for Group, Blocked for Others",
     "Owner has full control, group can view, outsiders blocked",
     "Semi-private programs"),
    (0o700, "Owner Only - Completely Private",
     "Only the owner can read, write, or run anything",
     "Private folders, sensitive scripts"),
