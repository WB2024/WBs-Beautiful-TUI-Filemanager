        print(f"      Change which group of users has group-level access")
        print()
        print(f"  {Colors.OKCYAN}[6]{Colors.ENDC} {Colors.BOLD}Set everything at once{Colors.ENDC}")
        print(f"      Pick permissions, owner, and group all in one go")
        print()
        print(f"  {Colors.OKCYAN}[7]{Colors.ENDC} {Colors.BOLD}Quick fix - Full Access for Everyone (777){Colors.ENDC}")
        print(f"      One-click: set 777 permissions recursively (original behavior)")
        print()
        print(f"  {Colors.OKCYAN}[q]{Colors.ENDC} Quit\n")

        while True:
            choice = input(f"{Colors.OKBLUE}Select an option: {Colors.ENDC}").strip()
            if choice in ['1', '2', '3', '4', '5', '6', '7']:
                return choice
            elif choice.lower() == 'q':
                return None
            else:
                self.print_warning("Please enter 1-7 or 'q'")

    def run(self):
        """Main interactive workflow"""
        while True:
            choice = self.show_main_menu()

            if choice is None:
                self.print_info("Goodbye!")
                break

            target = Path(self.current_dir)

            if choice == '1':
                # Inspect current directory
                self.inspect_path(target)
                input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")

            elif choice == '2':
                # Inspect contents
                self.inspect_children(target)
                input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")

            elif choice == '3':
                # Set permissions only
                preset = self.select_permission_preset()
                if preset:
                    scope = self.select_scope(target)
                    if scope:
                        recursive = (scope == 'recursive')
                        self.apply_permissions(target, preset, recursive=recursive)
                        input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")

            elif choice == '4':
                # Change owner only
                owner = self.select_owner()
                if owner:
                    scope = self.select_scope(target)
                    if scope:
                        recursive = (scope == 'recursive')
                        # Keep current permissions
                        st = target.stat()
                        current_perm = st.st_mode & 0o777
                        # Find matching preset or create a placeholder
                        matched = None
                        for p in PERMISSION_PRESETS:
                            if p[0] == current_perm:
                                matched = p
                                break
                        if not matched:
                            rwx = self.format_rwx(current_perm)
                            matched = (current_perm, f"Current ({self.format_octal(st.st_mode)})", rwx, "")
                        self.apply_permissions(target, matched, owner=owner, recursive=recursive)
                        input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")

            elif choice == '5':
                # Change group only
                group = self.select_group()
                if group:
                    scope = self.select_scope(target)
                    if scope:
                        recursive = (scope == 'recursive')
                        st = target.stat()
                        current_perm = st.st_mode & 0o777
                        matched = None
                        for p in PERMISSION_PRESETS:
                            if p[0] == current_perm:
                                matched = p
                                break
                        if not matched:
                            rwx = self.format_rwx(current_perm)
                            matched = (current_perm, f"Current ({self.format_octal(st.st_mode)})", rwx, "")
                        self.apply_permissions(target, matched, group=group, recursive=recursive)
                        input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")

            elif choice == '6':
                # Set everything
                preset = self.select_permission_preset()
                if not preset:
                    continue
                owner = self.select_owner()
                group = self.select_group()
                scope = self.select_scope(target)
                if scope:
                    recursive = (scope == 'recursive')
                    self.apply_permissions(target, preset, owner=owner, group=group, recursive=recursive)
                    input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")

            elif choice == '7':
                # Quick fix 777
                preset = (0o777, "Full Access for Everyone", "Anyone can read, write, and run files", "")
                if self.yes_no_prompt(f"\nSet Full Access (777) on everything in {target}?", default=True):
                    self.apply_permissions(target, preset, recursive=True)
                    input(f"\n{Colors.OKBLUE}Press Enter to continue...{Colors.ENDC}")


def main():
    """Entry point"""
    # Support legacy CLI usage: fixperms [directory] [owner:group]
    if len(sys.argv) > 1:
        if sys.argv[1] in ['-h', '--help']:
            print(f"""
{Colors.BOLD}Usage:{Colors.ENDC} fixperms [directory]

{Colors.BOLD}Interactive Permission Manager{Colors.ENDC}
Inspect and set file/folder permissions and ownership with human-readable options.

{Colors.BOLD}Arguments:{Colors.ENDC}
  directory     Target directory (default: current directory)

{Colors.BOLD}Examples:{Colors.ENDC}
  fixperms                    # Manage permissions in current directory
  fixperms /var/www           # Manage permissions for /var/www
  sudo fixperms               # Run with sudo for ownership changes

{Colors.BOLD}Note:{Colors.ENDC} Changing ownership typically requires sudo/root privileges.
""")
            sys.exit(0)

        # If a directory argument is given, change to it
        target = sys.argv[1]
        if os.path.isdir(target):
            os.chdir(target)
        else:
            print(f"{Colors.FAIL}✗ Error: '{target}' is not a directory{Colors.ENDC}")
            sys.exit(1)

    try:
        manager = PermissionManager()
        manager.run()
    except KeyboardInterrupt:
        print(f"\n\n{Colors.WARNING}Operation cancelled by user{Colors.ENDC}")
        sys.exit(0)
    except Exception as e:
        print(f"\n{Colors.FAIL}Unexpected error: {e}{Colors.ENDC}")
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
