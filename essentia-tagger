MOOD_MODEL = f"{MODEL_DIR}/mtg_jamendo_moodtheme-discogs-effnet-1.pb"
MOOD_METADATA = f"{MODEL_DIR}/mtg_jamendo_moodtheme-discogs-effnet-1.json"


def format_genre_tag(raw_genre, style='parent_child'):
    """Format genre tags for better readability"""
    if style == 'raw':
        return raw_genre

    if '---' in raw_genre:
        parts = raw_genre.split('---')
        parent = parts[0].strip()
        child = parts[1].strip() if len(parts) > 1 else ''

        if style == 'parent_child':
            return f"{parent} - {child}" if child else parent
        elif style == 'child_parent':
            return f"{child} - {parent}" if child else parent
        elif style == 'child_only':
            return child if child else parent

    return raw_genre


def format_mood_tag(raw_mood):
    """Format mood tags for better readability"""
    return raw_mood.title()


class Logger:
    """Dual output to console and log file"""
    def __init__(self, log_file):
        self.log_file = log_file
        self.file_handle = open(log_file, 'w', encoding='utf-8')
        self.write_header()

    def write_header(self):
        header = f"""
{'=' * 80}
ESSENTIA MUSIC TAGGER - LOG FILE
Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}
{'=' * 80}

"""
        self.file_handle.write(header)
        self.file_handle.flush()

    def log(self, message, console=True, file=True):
        if console:
            print(message)
        if file:
            self.file_handle.write(message + '\n')
            self.file_handle.flush()

    def log_config(self, config, music_path):
        if config.enable_genres and config.enable_moods:
            mode_label = "Genres & Moods"
        elif config.enable_genres:
            mode_label = "Genres only"
        else:
            mode_label = "Moods only"

        config_text = f"""
CONFIGURATION:
{'-' * 80}
Target Directory: {music_path}
Model Directory: {MODEL_DIR}
Analysis Mode: {mode_label}
"""
        if config.enable_genres:
            config_text += f"""Genre Settings:
  - Number of genres: {config.top_n_genres}
  - Confidence threshold: {config.genre_threshold:.1%}
  - Genre format: {config.genre_format}
"""
        if config.enable_moods:
            config_text += f"""Mood Settings:
  - Confidence threshold: {config.mood_threshold:.1%}
"""
        config_text += f"""Other Settings:
  - Dry run mode: {config.dry_run}
  - Write confidence tags: {config.write_confidence_tags}
  - Overwrite existing: {config.overwrite_existing}
  - Verbose output: {config.verbose}
{'=' * 80}

"""
        self.file_handle.write(config_text)
        self.file_handle.flush()

    def log_analysis(self, filepath, results, relative_path):
        log_entry = f"""
FILE: {relative_path}
{'-' * 80}
"""
        if results.get('genres'):
            log_entry += "GENRES (raw predictions):\n"
            for g in results['genres']:
                log_entry += f"  • {g['label']}: {g['confidence']:.2%}\n"
        elif 'genres' not in results:
            log_entry += "GENRES: Disabled\n"
        else:
            log_entry += "GENRES: None passed threshold\n"

        if results.get('formatted_genres'):
            log_entry += "\nGENRES (formatted for tags):\n"
            for fg in results['formatted_genres']:
                log_entry += f"  • {fg}\n"

        if results.get('all_genres_debug'):
            log_entry += "\nALL GENRE PREDICTIONS (top 10):\n"
            for label, conf in results['all_genres_debug']:
                log_entry += f"  • {label}: {conf:.2%}\n"

        if results.get('moods'):
            log_entry += f"\nMOODS (raw predictions - {len(results['moods'])} total):\n"
            for m in results['moods']:
                log_entry += f"  • {m['label']}: {m['confidence']:.2%}\n"
        elif 'moods' not in results:
            log_entry += "\nMOODS: Disabled\n"
        else:
            log_entry += "\nMOODS: None passed threshold\n"

        if results.get('formatted_moods'):
            log_entry += "\nMOODS (formatted for tags):\n"
            for fm in results['formatted_moods']:
                log_entry += f"  • {fm}\n"

        if results.get('all_moods_debug'):
            log_entry += "\nALL MOOD PREDICTIONS (top 10):\n"
            for label, conf in results['all_moods_debug'][:10]:
                log_entry += f"  • {label}: {conf:.2%}\n"

        log_entry += f"\n{'=' * 80}\n"
        self.file_handle.write(log_entry)
        self.file_handle.flush()

    def log_summary(self, processed, errors, skipped):
        summary = f"""
{'=' * 80}
PROCESSING SUMMARY
{'=' * 80}
Total Processed: {processed}
Errors: {errors}
Skipped: {skipped}
Completed: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}
{'=' * 80}
"""
        self.file_handle.write(summary)
        self.file_handle.flush()

    def close(self):
        self.file_handle.close()


class Config:
    """Runtime configuration"""
    def __init__(self):
        self.dry_run = True
        self.enable_genres = True
        self.enable_moods = True
        self.top_n_genres = 3
        self.genre_threshold = 0.15
        self.mood_threshold = 0.005
        self.write_confidence_tags = True
        self.overwrite_existing = False
        self.verbose = True
        self.log_file = None
        self.genre_format = 'parent_child'


class EssentiaTagger:
    """Main tagger workflow - standalone tool for the filemanager"""

    def __init__(self):
        self.current_dir = os.getcwd()

    def print_header(self, text):
        print(f"\n{Colors.HEADER}{Colors.BOLD}{'='*70}{Colors.ENDC}")
        print(f"{Colors.HEADER}{Colors.BOLD}{text.center(70)}{Colors.ENDC}")
        print(f"{Colors.HEADER}{Colors.BOLD}{'='*70}{Colors.ENDC}\n")

    def print_success(self, text):
        print(f"{Colors.OKGREEN}✓ {text}{Colors.ENDC}")

    def print_error(self, text):
        print(f"{Colors.FAIL}✗ {text}{Colors.ENDC}")

    def print_info(self, text):
        print(f"{Colors.OKCYAN}ℹ {text}{Colors.ENDC}")

    def print_warning(self, text):
        print(f"{Colors.WARNING}⚠ {text}{Colors.ENDC}")

    def yes_no_prompt(self, question, default=True):
        default_text = "Y/n" if default else "y/N"
        while True:
            response = input(f"{Colors.OKBLUE}{question} ({default_text}): {Colors.ENDC}").lower().strip()
            if response == '':
                return default
            if response in ['y', 'yes']:
                return True
            elif response in ['n', 'no']:
                return False
            else:
                self.print_warning("Please answer 'y' or 'n'")

    def get_int_input(self, prompt, default, min_val=None, max_val=None):
        while True:
            user_input = input(f"{Colors.OKBLUE}{prompt} [{default}]: {Colors.ENDC}").strip()
            if not user_input:
                return default
            try:
                value = int(user_input)
                if min_val is not None and value < min_val:
                    self.print_warning(f"Must be at least {min_val}")
                    continue
                if max_val is not None and value > max_val:
                    self.print_warning(f"Must be at most {max_val}")
                    continue
                return value
            except ValueError:
                self.print_warning("Please enter a valid number")

    def get_float_input(self, prompt, default, min_val=None, max_val=None):
        while True:
            user_input = input(f"{Colors.OKBLUE}{prompt} [{default}]: {Colors.ENDC}").strip()
            if not user_input:
                return default
            try:
                value = float(user_input)
                if min_val is not None and value < min_val:
                    self.print_warning(f"Must be at least {min_val}")
                    continue
                if max_val is not None and value > max_val:
                    self.print_warning(f"Must be at most {max_val}")
                    continue
                return value
            except ValueError:
                self.print_warning("Please enter a valid number")

    def check_dependencies(self):
        """Check if required Python packages and models are available"""
        # Check essentia
        try:
            import essentia
            essentia.log.warningActive = False
            from essentia.standard import MonoLoader, TensorflowPredictEffnetDiscogs, TensorflowPredict2D
            self.print_success("Essentia library found")
        except ImportError:
            self.print_error("Essentia library not installed")
            self.print_info("Install with: pip install essentia-tensorflow")
            return False

        # Check mutagen
        try:
            import mutagen
            self.print_success("Mutagen library found")
        except ImportError:
            self.print_error("Mutagen library not installed")
            self.print_info("Install with: pip install mutagen")
            return False

        # Check numpy
        try:
            import numpy
            self.print_success("NumPy library found")
        except ImportError:
            self.print_error("NumPy library not installed")
            self.print_info("Install with: pip install numpy")
            return False

        # Check models
        models_ok = True
        for model_file in [EMBEDDING_MODEL, GENRE_MODEL, GENRE_METADATA, MOOD_MODEL, MOOD_METADATA]:
            if not os.path.exists(model_file):
                self.print_error(f"Model not found: {model_file}")
                models_ok = False

        if not models_ok:
            self.print_error("Essentia models not downloaded")
            self.print_info(f"Models should be in: {MODEL_DIR}")
            self.print_info("Download models with:")
            print(f"  {Colors.OKCYAN}mkdir -p {MODEL_DIR}{Colors.ENDC}")
            print(f"  {Colors.OKCYAN}cd {MODEL_DIR}{Colors.ENDC}")
            print(f"  {Colors.OKCYAN}wget https://essentia.upf.edu/models/music-style-classification/discogs-effnet/discogs-effnet-bs64-1.pb{Colors.ENDC}")
            print(f"  {Colors.OKCYAN}wget https://essentia.upf.edu/models/classification-heads/genre_discogs400/genre_discogs400-discogs-effnet-1.pb{Colors.ENDC}")
            print(f"  {Colors.OKCYAN}wget https://essentia.upf.edu/models/classification-heads/genre_discogs400/genre_discogs400-discogs-effnet-1.json{Colors.ENDC}")
            print(f"  {Colors.OKCYAN}wget https://essentia.upf.edu/models/classification-heads/mtg_jamendo_moodtheme/mtg_jamendo_moodtheme-discogs-effnet-1.pb{Colors.ENDC}")
            print(f"  {Colors.OKCYAN}wget https://essentia.upf.edu/models/classification-heads/mtg_jamendo_moodtheme/mtg_jamendo_moodtheme-discogs-effnet-1.json{Colors.ENDC}")
            return False

        self.print_success("All models found")
        return True

    def scan_directory(self):
        """Scan current directory for audio files (recursively)"""
        self.print_header("Scanning Directory")
        self.print_info(f"Directory: {self.current_dir}")

        root = Path(self.current_dir)
        all_files = list(root.rglob('*'))
        audio_files = sorted([f for f in all_files if f.suffix.lower() in AUDIO_EXTENSIONS])

        if not audio_files:
            self.print_warning("No audio files found in current directory")
            return []

        self.print_success(f"Found {len(audio_files)} audio file(s)")

        # Show summary by extension
        ext_counts = {}
        for f in audio_files:
            ext = f.suffix.lower()
            ext_counts[ext] = ext_counts.get(ext, 0) + 1

        print(f"\n{Colors.BOLD}File types:{Colors.ENDC}")
        for ext, count in sorted(ext_counts.items(), key=lambda x: -x[1]):
            print(f"  {ext}: {count}")

        return audio_files

    def configure_settings(self):
        """Interactive configuration"""
        config = Config()

        self.print_header("Configuration")
        print(f"{Colors.BOLD}Press Enter to accept defaults shown in [brackets]{Colors.ENDC}\n")

        # Dry run mode
        print(f"{Colors.BOLD}🧪 DRY RUN MODE{Colors.ENDC}")
        print("  Test mode - analyzes files but doesn't write tags")
        print("  Recommended: Enable for first run to see results")
        config.dry_run = self.yes_no_prompt("Enable dry run mode?", default=True)

        # Analysis mode
        print(f"\n{Colors.BOLD}🎯 ANALYSIS MODE{Colors.ENDC}")
        print("  1 = Genres & Moods (both)")
        print("  2 = Genres only")
        print("  3 = Moods only")
        mode_choice = self.get_int_input("Analysis mode", default=1, min_val=1, max_val=3)
        config.enable_genres = mode_choice in (1, 2)
        config.enable_moods = mode_choice in (1, 3)

        # Genre settings
        if config.enable_genres:
            print(f"\n{Colors.BOLD}🎸 GENRE SETTINGS{Colors.ENDC}")
            print("  Number of genre tags to write per song (1-10)")
            config.top_n_genres = self.get_int_input("Number of genres", default=3, min_val=1, max_val=10)

            print(f"\n  Genre confidence threshold (as percentage)")
            print("  5% = inclusive | 15% = balanced | 25% = strict")
            threshold_pct = self.get_float_input("Genre threshold (%)", default=15, min_val=1, max_val=50)
            config.genre_threshold = threshold_pct / 100.0

            print(f"\n  Genre tag formatting:")
            print("  1 = 'Rock - Alternative Rock' (parent - child)")
            print("  2 = 'Alternative Rock - Rock' (child - parent)")
            print("  3 = 'Alternative Rock' (child only)")
            print("  4 = 'Rock---Alternative Rock' (raw)")
            format_choice = self.get_int_input("Genre format", default=1, min_val=1, max_val=4)
            format_map = {1: 'parent_child', 2: 'child_parent', 3: 'child_only', 4: 'raw'}
            config.genre_format = format_map[format_choice]

        # Mood settings
        if config.enable_moods:
            print(f"\n{Colors.BOLD}😊 MOOD SETTINGS{Colors.ENDC}")
            print("  Mood predictions are typically MUCH lower confidence than genres")
            print("  0.5% = inclusive (recommended) | 1% = balanced | 3% = strict")
            mood_threshold_pct = self.get_float_input("Mood threshold (%)", default=0.5, min_val=0.01, max_val=20)
            config.mood_threshold = mood_threshold_pct / 100.0

        # Confidence tags
        print(f"\n{Colors.BOLD}📊 CONFIDENCE SCORES{Colors.ENDC}")
        print("  Write confidence percentages to additional tags")
        config.write_confidence_tags = self.yes_no_prompt("Write confidence score tags?", default=True)

        # Overwrite existing
        print(f"\n{Colors.BOLD}♻️  EXISTING TAGS{Colors.ENDC}")
        config.overwrite_existing = self.yes_no_prompt("Overwrite existing genre/mood tags?", default=False)

        # Verbose
        print(f"\n{Colors.BOLD}📢 VERBOSE OUTPUT{Colors.ENDC}")
        config.verbose = self.yes_no_prompt("Enable verbose output?", default=True)

        return config

