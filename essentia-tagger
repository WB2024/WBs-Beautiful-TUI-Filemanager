    def process_files(self, audio_files, config):
        """Load models and process all audio files"""
        import numpy as np
        from essentia.standard import MonoLoader, TensorflowPredictEffnetDiscogs, TensorflowPredict2D
        import mutagen
        from mutagen.flac import FLAC
        from mutagen.id3 import ID3, TCON, COMM
        from mutagen.oggvorbis import OggVorbis
        from mutagen.oggopus import OggOpus
        from mutagen.mp4 import MP4
        from mutagen.aiff import AIFF
        from mutagen.asf import ASF

        logger = Logger(config.log_file)
        logger.log_config(config, self.current_dir)

        # Load models
        logger.log("\n🔄 Loading models...")

        embedding_model = TensorflowPredictEffnetDiscogs(
            graphFilename=EMBEDDING_MODEL,
            output="PartitionedCall:1"
        )

        genre_model = None
        genre_labels = None
        if config.enable_genres:
            genre_model = TensorflowPredict2D(
                graphFilename=GENRE_MODEL,
                input="serving_default_model_Placeholder",
                output="PartitionedCall"
            )
            with open(GENRE_METADATA, 'r') as f:
                metadata = json.load(f)
                genre_labels = metadata['classes']
            logger.log(f"   ✅ Loaded {len(genre_labels)} genre classes")
        else:
            logger.log("   ⏭️  Genre analysis disabled")

        mood_model = None
        mood_labels = None
        if config.enable_moods and os.path.exists(MOOD_MODEL):
            logger.log("   Loading mood model...")
            try:
                mood_model = TensorflowPredict2D(
                    graphFilename=MOOD_MODEL,
                    input="model/Placeholder",
                    output="model/Sigmoid"
                )
                with open(MOOD_METADATA, 'r') as f:
                    metadata = json.load(f)
                    mood_labels = metadata['classes']
                logger.log(f"   ✅ Loaded {len(mood_labels)} mood classes")
            except Exception as e:
                logger.log(f"   ⚠️  Could not load mood model: {e}")
                mood_model = None
        elif not config.enable_moods:
            logger.log("   ⏭️  Mood analysis disabled")
        else:
            logger.log("   ⚠️  Mood model not found")

        logger.log("   ✅ Models loaded successfully!\n")

        root = Path(self.current_dir)
        processed = 0
        errors = 0
        skipped = 0

        logger.log(f"{'=' * 70}\n")

        for i, filepath in enumerate(audio_files, 1):
            try:
                relative_path = filepath.relative_to(root)
            except ValueError:
                relative_path = filepath.name

            logger.log(f"[{i}/{len(audio_files)}] {relative_path}")

            # Analyze
            try:
                audio = MonoLoader(
                    filename=str(filepath),
                    sampleRate=16000,
                    resampleQuality=4
                )()

                embeddings = embedding_model(audio)
                results = {}

                # Predict genres
                if genre_model:
                    genre_predictions = genre_model(embeddings)
                    genre_activations = np.mean(genre_predictions, axis=0)

                    top_indices = np.argsort(genre_activations)[::-1][:config.top_n_genres * 2]
                    genres = []
                    for idx in top_indices:
                        if len(genres) >= config.top_n_genres:
                            break
                        if genre_activations[idx] >= config.genre_threshold:
                            genres.append({
                                'label': genre_labels[idx],
                                'confidence': float(genre_activations[idx])
                            })

                    if not genres:
                        top_idx = np.argmax(genre_activations)
                        genres.append({
                            'label': genre_labels[top_idx],
                            'confidence': float(genre_activations[top_idx])
                        })

                    results['genres'] = genres
                    results['formatted_genres'] = [
                        format_genre_tag(g['label'], style=config.genre_format)
                        for g in genres
                    ]

                    all_top_indices = np.argsort(genre_activations)[::-1][:10]
                    results['all_genres_debug'] = [
                        (genre_labels[idx], float(genre_activations[idx]))
                        for idx in all_top_indices
                    ]

                # Predict moods
                if mood_model:
                    mood_predictions = mood_model(embeddings)
                    mood_activations = np.mean(mood_predictions, axis=0)

                    moods = []
                    for idx, activation in enumerate(mood_activations):
                        if activation >= config.mood_threshold:
                            moods.append({
                                'label': mood_labels[idx],
                                'confidence': float(activation)
                            })

                    moods = sorted(moods, key=lambda x: x['confidence'], reverse=True)
                    results['moods'] = moods[:5]

                    results['formatted_moods'] = [
                        format_mood_tag(m['label'])
                        for m in results['moods']
                    ]

                    results['all_moods_debug'] = sorted(
                        [(mood_labels[idx], float(mood_activations[idx]))
                         for idx in range(len(mood_activations))],
                        key=lambda x: x[1], reverse=True
                    )

                # Print results
                if config.enable_genres:
                    if results.get('genres'):
                        genre_list = [f"{g['label']} ({g['confidence']:.1%})" for g in results['genres']]
                        logger.log(f"     🎸 Raw: {', '.join(genre_list)}")
                    if results.get('formatted_genres'):
                        logger.log(f"     🎸 Formatted: {', '.join(results['formatted_genres'])}")

                if config.enable_moods:
                    if results.get('moods'):
                        mood_list = [f"{m['label']} ({m['confidence']:.1%})" for m in results['moods'][:3]]
                        logger.log(f"     😊 Raw: {', '.join(mood_list)}")
                    if results.get('formatted_moods'):
                        logger.log(f"     😊 Formatted: {', '.join(results['formatted_moods'][:3])}")
                    elif results.get('moods') is not None and len(results.get('moods', [])) == 0:
                        logger.log(f"     😊 Moods: None above threshold ({config.mood_threshold:.2%})")

                if config.verbose and results.get('all_genres_debug'):
                    top_5 = ', '.join([f"{label} ({conf:.1%})" for label, conf in results['all_genres_debug'][:5]])
                    logger.log(f"     📊 Top 5 genres: {top_5}", console=False)

                logger.log_analysis(filepath, results, relative_path)

                # Write tags
                self._write_tags(filepath, results, config, logger, mutagen, FLAC, ID3, TCON, COMM,
                                 OggVorbis, OggOpus, MP4, AIFF, ASF)

                if config.dry_run:
                    tag_info = []
                    if config.enable_genres and results.get('formatted_genres'):
                        tag_info.append(f"Genres: {', '.join(results['formatted_genres'])}")
                    if config.enable_moods and results.get('formatted_moods'):
                        tag_info.append(f"Moods: {', '.join(results['formatted_moods'][:3])}")
                    logger.log(f"     [DRY RUN] Would write: {' | '.join(tag_info)}")
                else:
                    logger.log("     ✅ Tags written")

                processed += 1

            except Exception as e:
                logger.log(f"     ⚠️  Error: {e}")
                errors += 1

            logger.log("")

        # Summary
        logger.log(f"\n{'=' * 70}")
        logger.log(f"📊 SUMMARY")
        logger.log(f"{'=' * 70}")
        logger.log(f"✅ Processed: {processed}")
        logger.log(f"❌ Errors: {errors}")
        logger.log(f"⏭️  Skipped: {skipped}")

        logger.log_summary(processed, errors, skipped)
        logger.log(f"\n📝 Full log saved to: {config.log_file}")
        logger.close()

    def _write_tags(self, filepath, results, config, logger, mutagen, FLAC, ID3, TCON, COMM,
                    OggVorbis, OggOpus, MP4, AIFF, ASF):
        """Write analysis results to audio file tags"""
        if config.dry_run:
            return

        try:
            file_ext = filepath.suffix.lower()

            if file_ext == '.flac':
                audio = FLAC(filepath)
                tags_written = self._write_vorbis_comments(audio, results, config)
                if tags_written:
                    audio.save()
            elif file_ext == '.mp3':
                try:
                    audio = ID3(filepath)
                except Exception:
                    audio = ID3()
                self._write_id3_tags(audio, results, config, TCON, COMM)
                audio.save(filepath)
            elif file_ext in ('.ogg', '.oga'):
                audio = OggVorbis(filepath)
                tags_written = self._write_vorbis_comments(audio, results, config)
                if tags_written:
                    audio.save()
            elif file_ext == '.opus':
                audio = OggOpus(filepath)
                tags_written = self._write_vorbis_comments(audio, results, config)
                if tags_written:
                    audio.save()
            elif file_ext in ('.m4a', '.m4b', '.mp4', '.aac'):
                audio = MP4(filepath)
                self._write_mp4_tags(audio, results, config, mutagen)
            elif file_ext == '.wma':
                audio = ASF(filepath)
                self._write_wma_tags(audio, results, config)
            elif file_ext in ('.aiff', '.aif'):
                audio = AIFF(filepath)
                if audio.tags is None:
                    audio.add_tags()
                self._write_id3_tags(audio.tags, results, config, TCON, COMM)
                audio.save()
            elif file_ext in ('.wav', '.dsf'):
                audio = mutagen.File(filepath)
                if audio is None:
                    return
                if audio.tags is None:
                    audio.add_tags()
                self._write_id3_tags(audio.tags, results, config, TCON, COMM)
                audio.save()
            elif file_ext in ('.wv', '.ape', '.mpc', '.mp+'):
                self._write_apev2_tags(filepath, results, config, mutagen)

        except Exception as e:
            logger.log(f"     ⚠️  Error writing tags: {e}")

    def _write_vorbis_comments(self, audio, results, config):
        """Write Vorbis comments (FLAC, OGG, Opus)"""
        tags_written = []

        if config.enable_genres and results.get('formatted_genres'):
            if config.overwrite_existing or 'GENRE' not in audio:
                genre_str = '; '.join(results['formatted_genres'])
                audio['GENRE'] = genre_str
                tags_written.append('GENRE')

                if config.write_confidence_tags and results.get('genres'):
                    genre_details = [f"{g['label']}: {g['confidence']:.2%}" for g in results['genres']]
                    audio['ESSENTIA_GENRE'] = f"Essentia: {', '.join(genre_details)}"
                    tags_written.append('ESSENTIA_GENRE')

        if config.enable_moods and results.get('formatted_moods'):
            if config.overwrite_existing or 'MOOD' not in audio:
                mood_str = '; '.join(results['formatted_moods'][:3])
                audio['MOOD'] = mood_str
                tags_written.append('MOOD')

                if config.write_confidence_tags and results.get('moods'):
                    mood_details = [f"{m['label']}: {m['confidence']:.2%}" for m in results['moods'][:3]]
                    audio['ESSENTIA_MOOD'] = f"Essentia: {', '.join(mood_details)}"
                    tags_written.append('ESSENTIA_MOOD')

        return tags_written

    def _write_id3_tags(self, tags, results, config, TCON, COMM):
        """Write ID3v2 tags (MP3, AIFF, WAV, DSF)"""
        if config.enable_genres and results.get('formatted_genres'):
            has_existing_genre = bool(tags.getall('TCON'))
            if config.overwrite_existing or not has_existing_genre:
                genre_str = '; '.join(results['formatted_genres'])
                tags.delall('TCON')
                tags.add(TCON(encoding=3, text=genre_str))

                if config.write_confidence_tags and results.get('genres'):
                    genre_details = [f"{g['label']}: {g['confidence']:.2%}" for g in results['genres']]
                    confidence_str = ', '.join(genre_details)
                    tags.delall('COMM::eng')
                    tags.add(COMM(
                        encoding=3,
                        lang='eng',
                        desc='Essentia Genre',
                        text=confidence_str
                    ))

        if config.enable_moods and results.get('formatted_moods'):
            mood_str = '; '.join(results['formatted_moods'][:3])
            tags.add(COMM(
                encoding=3,
                lang='eng',
                desc='Essentia Mood',
                text=mood_str
            ))

    def _write_mp4_tags(self, audio, results, config, mutagen):
        """Write MP4/M4A/AAC tags"""
        tags_written = []

        if config.enable_genres and results.get('formatted_genres'):
            has_existing = '\xa9gen' in audio.tags if audio.tags else False
            if config.overwrite_existing or not has_existing:
                genre_str = '; '.join(results['formatted_genres'])
                audio['\xa9gen'] = [genre_str]
                tags_written.append('genre')

                if config.write_confidence_tags and results.get('genres'):
                    genre_details = [f"{g['label']}: {g['confidence']:.2%}" for g in results['genres']]
                    audio['\xa9cmt'] = [f"Essentia Genre: {', '.join(genre_details)}"]

        if config.enable_moods and results.get('formatted_moods'):
            mood_str = '; '.join(results['formatted_moods'][:3])
            audio['----:com.apple.iTunes:MOOD'] = [
                mutagen.mp4.MP4FreeForm(mood_str.encode('utf-8'),
                                        dataformat=mutagen.mp4.AtomDataType.UTF8)
            ]
            tags_written.append('MOOD')

        if tags_written:
            audio.save()

    def _write_wma_tags(self, audio, results, config):
        """Write WMA/ASF tags"""
        tags_written = []

        if config.enable_genres and results.get('formatted_genres'):
            has_existing = 'WM/Genre' in audio if audio.tags else False
            if config.overwrite_existing or not has_existing:
                genre_str = '; '.join(results['formatted_genres'])
                audio['WM/Genre'] = genre_str
                tags_written.append('WM/Genre')

        if config.enable_moods and results.get('formatted_moods'):
            mood_str = '; '.join(results['formatted_moods'][:3])
            audio['WM/Mood'] = mood_str
            tags_written.append('WM/Mood')

        if tags_written:
            audio.save()

    def _write_apev2_tags(self, filepath, results, config, mutagen):
        """Write APEv2 tags (WavPack, APE, Musepack)"""
        try:
            audio = mutagen.File(filepath)
            if audio is None:
                return
            if audio.tags is None:
                audio.add_tags()
        except Exception:
            return

        tags_written = []

        if config.enable_genres and results.get('formatted_genres'):
            has_existing = 'Genre' in audio.tags
            if config.overwrite_existing or not has_existing:
                genre_str = '; '.join(results['formatted_genres'])
                audio.tags['Genre'] = genre_str
                tags_written.append('Genre')

                if config.write_confidence_tags and results.get('genres'):
                    genre_details = [f"{g['label']}: {g['confidence']:.2%}" for g in results['genres']]
                    audio.tags['Essentia Genre'] = f"Essentia: {', '.join(genre_details)}"

        if config.enable_moods and results.get('formatted_moods'):
            mood_str = '; '.join(results['formatted_moods'][:3])
            audio.tags['Mood'] = mood_str
            tags_written.append('Mood')

        if tags_written:
            audio.save()

    def run(self):
        """Main workflow"""
        self.print_header("Essentia Music Tagger")
        self.print_info("Analyze audio with ML models and write genre/mood tags")
        self.print_info("Based on: https://github.com/WB2024/Essentia-to-Metadata")

        # Check dependencies
        print()
        if not self.check_dependencies():
            return

        # Scan directory
        audio_files = self.scan_directory()
        if not audio_files:
            return

        # Confirm
        if not self.yes_no_prompt(f"\nProceed with tagging {len(audio_files)} file(s)?", default=True):
            self.print_info("Cancelled")
            return

        # Configure
        config = self.configure_settings()

        # Show summary
        self.show_config_summary(config, len(audio_files))

        if not config.dry_run:
            if not self.yes_no_prompt("\nReady to proceed?", default=True):
                self.print_info("Cancelled")
                return

        # Process
        self.print_header(f"Processing {len(audio_files)} File(s)")
        self.process_files(audio_files, config)

        self.print_header("Tagging Complete")


def parse_arguments():
    """Parse command-line arguments for automated mode"""
    parser = argparse.ArgumentParser(
        description='Analyze audio files with Essentia ML and write genre/mood tags',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Interactive mode (run in current directory)
  essentia-tagger

  # Automated mode with path
  essentia-tagger /path/to/music --auto

  # Custom settings
  essentia-tagger /path/to/music --auto --genres 4 --genre-threshold 20

  # Dry run
  essentia-tagger /path/to/music --auto --dry-run

  # Single file
  essentia-tagger /path/to/song.flac --auto --single-file
"""
    )

    parser.add_argument('path', nargs='?', help='Path to music file or directory')
    parser.add_argument('--auto', '-a', action='store_true', help='Non-interactive mode')
    parser.add_argument('--single-file', '-f', action='store_true', help='Process a single file')
    parser.add_argument('--genres', '-g', type=int, default=3, metavar='N', help='Number of genres (default: 3)')
    parser.add_argument('--genre-threshold', '-gt', type=float, default=15.0, metavar='PCT', help='Genre threshold %% (default: 15)')
    parser.add_argument('--genre-format', '-gf', choices=['parent_child', 'child_parent', 'child_only', 'raw'], default='parent_child')
    parser.add_argument('--no-genres', action='store_true', help='Disable genre analysis')
    parser.add_argument('--no-moods', action='store_true', help='Disable mood analysis')
    parser.add_argument('--mood-threshold', '-mt', type=float, default=0.5, metavar='PCT', help='Mood threshold %% (default: 0.5)')
    parser.add_argument('--dry-run', '-d', action='store_true', help='Don\'t write tags')
    parser.add_argument('--no-confidence-tags', action='store_true', help='Skip confidence tags')
    parser.add_argument('--overwrite', '-o', action='store_true', help='Overwrite existing tags')
    parser.add_argument('--quiet', '-q', action='store_true', help='Minimal output')
    parser.add_argument('--log-dir', type=str, default=None, metavar='DIR', help='Log file directory')
    parser.add_argument('--model-dir', type=str, default=None, metavar='DIR', help='Essentia models directory')

    return parser.parse_args()


def main():
    """Entry point"""
    args = parse_arguments()

    if args.auto or args.single_file:
        # Automated/CLI mode
        if not args.path:
            print(f"{Colors.FAIL}✗ Error: Path is required in automated mode{Colors.ENDC}")
            print("  Use: essentia-tagger /path/to/music --auto")
            sys.exit(1)

        if args.no_genres and args.no_moods:
            print(f"{Colors.FAIL}✗ Error: Cannot disable both genres and moods{Colors.ENDC}")
            sys.exit(1)

        # Update model dir if specified
        global MODEL_DIR, EMBEDDING_MODEL, GENRE_MODEL, GENRE_METADATA, MOOD_MODEL, MOOD_METADATA
        if args.model_dir:
            MODEL_DIR = os.path.expanduser(args.model_dir)
            EMBEDDING_MODEL = f"{MODEL_DIR}/discogs-effnet-bs64-1.pb"
            GENRE_MODEL = f"{MODEL_DIR}/genre_discogs400-discogs-effnet-1.pb"
            GENRE_METADATA = f"{MODEL_DIR}/genre_discogs400-discogs-effnet-1.json"
            MOOD_MODEL = f"{MODEL_DIR}/mtg_jamendo_moodtheme-discogs-effnet-1.pb"
            MOOD_METADATA = f"{MODEL_DIR}/mtg_jamendo_moodtheme-discogs-effnet-1.json"

        config = Config()
        config.dry_run = args.dry_run
        config.enable_genres = not args.no_genres
        config.enable_moods = not args.no_moods
        config.top_n_genres = args.genres
        config.genre_threshold = args.genre_threshold / 100.0
        config.mood_threshold = args.mood_threshold / 100.0
        config.write_confidence_tags = not args.no_confidence_tags
        config.overwrite_existing = args.overwrite
        config.verbose = not args.quiet
        config.genre_format = args.genre_format

        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        log_filename = f"essentia_tagger_{timestamp}.log"
        if args.log_dir:
            log_dir = Path(args.log_dir)
            log_dir.mkdir(parents=True, exist_ok=True)
            config.log_file = str(log_dir / log_filename)
        else:
            config.log_file = log_filename

        music_path = os.path.expanduser(args.path)

        tagger = EssentiaTagger()
        tagger.current_dir = music_path if not args.single_file else os.path.dirname(music_path)

        if not tagger.check_dependencies():
            sys.exit(1)

        if args.single_file:
            # Single file mode
            filepath = Path(music_path)
            if not filepath.exists():
                print(f"{Colors.FAIL}✗ File not found: {filepath}{Colors.ENDC}")
                sys.exit(1)
            if filepath.suffix.lower() not in AUDIO_EXTENSIONS:
                print(f"{Colors.FAIL}✗ Not an audio file: {filepath}{Colors.ENDC}")
                sys.exit(1)
            tagger.process_files([filepath], config)
        else:
            if not os.path.isdir(music_path):
                print(f"{Colors.FAIL}✗ Not a directory: {music_path}{Colors.ENDC}")
                sys.exit(1)
            audio_files = tagger.scan_directory()
            if audio_files:
                tagger.process_files(audio_files, config)

    else:
        # Interactive mode
        try:
            tagger = EssentiaTagger()
            tagger.run()
        except KeyboardInterrupt:
            print(f"\n\n{Colors.WARNING}Operation cancelled by user{Colors.ENDC}")
            sys.exit(0)
        except Exception as e:
            print(f"\n{Colors.FAIL}Unexpected error: {e}{Colors.ENDC}")
            import traceback
            traceback.print_exc()
            sys.exit(1)


if __name__ == "__main__":
    main()
