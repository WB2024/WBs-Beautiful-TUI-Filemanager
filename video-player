#!/usr/bin/env python3
"""
Video Player - Terminal Video Player Wrapper
Plays videos in the terminal using buddy or ncplayer
Supports: buddy (https://github.com/JVSCHANDRADITHYA/buddy)
          ncplayer (https://github.com/dankamongmen/notcurses)
"""

import os
import subprocess
import sys
import shutil
import signal
import json
from pathlib import Path

# Config file (shared with filemanager)
CONFIG_FILE = Path.home() / '.filemanager_config.json'

class Colors:
    """ANSI color codes for terminal output"""
    HEADER = '\033[95m'
    OKBLUE = '\033[94m'
    OKCYAN = '\033[96m'
    OKGREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'

class VideoPlayer:
    def __init__(self):
        self.current_dir = os.getcwd()
        self.video_extensions = [
            '.mp4', '.mkv', '.avi', '.mov', '.wmv', '.flv', '.webm',
            '.m4v', '.mpg', '.mpeg', '.3gp', '.ogv', '.ts', '.m2ts',
            '.vob', '.divx', '.xvid', '.f4v', '.rm', '.rmvb'
        ]
        
        self.files_found = []
        self.player_preference = self.load_player_preference()
        
    def load_player_preference(self):
        """Load video player preference from config"""
        if CONFIG_FILE.exists():
            try:
                with open(CONFIG_FILE, 'r') as f:
                    data = json.load(f)
                    return data.get('video_player', 'auto')
            except:
                pass
        return 'auto'
    
    def save_player_preference(self, player):
        """Save video player preference to config"""
        data = {}
        if CONFIG_FILE.exists():
            try:
                with open(CONFIG_FILE, 'r') as f:
                    data = json.load(f)
            except:
                pass
        
        data['video_player'] = player
        try:
            with open(CONFIG_FILE, 'w') as f:
                json.dump(data, f, indent=2)
        except:
            pass
        
        self.player_preference = player
        
    def print_header(self, text):
        """Print a formatted header"""
        print(f"\n{Colors.HEADER}{Colors.BOLD}{'='*70}{Colors.ENDC}")
        print(f"{Colors.HEADER}{Colors.BOLD}{text.center(70)}{Colors.ENDC}")
        print(f"{Colors.HEADER}{Colors.BOLD}{'='*70}{Colors.ENDC}\n")
    
    def print_success(self, text):
        """Print success message"""
        print(f"{Colors.OKGREEN}✓ {text}{Colors.ENDC}")
    
    def print_error(self, text):
        """Print error message"""
        print(f"{Colors.FAIL}✗ {text}{Colors.ENDC}")
    
    def print_info(self, text):
        """Print info message"""
        print(f"{Colors.OKCYAN}ℹ {text}{Colors.ENDC}")
    
    def print_warning(self, text):
        """Print warning message"""
        print(f"{Colors.WARNING}⚠ {text}{Colors.ENDC}")
    
    def check_players_installed(self):
        """Check which video players are available"""
        players = {}
        
        # Check buddy
        buddy_path = shutil.which('buddy')
        if buddy_path:
            players['buddy'] = buddy_path
        
        # Check ncplayer (part of notcurses)
        ncplayer_path = shutil.which('ncplayer')
        if ncplayer_path:
            players['ncplayer'] = ncplayer_path
        
        return players
    
    def get_player(self, available_players):
        """Get the player to use based on preference"""
        if self.player_preference == 'buddy' and 'buddy' in available_players:
            return 'buddy', available_players['buddy']
        elif self.player_preference == 'ncplayer' and 'ncplayer' in available_players:
            return 'ncplayer', available_players['ncplayer']
        elif self.player_preference == 'auto':
            # Prefer buddy, fall back to ncplayer
            if 'buddy' in available_players:
                return 'buddy', available_players['buddy']
            elif 'ncplayer' in available_players:
                return 'ncplayer', available_players['ncplayer']
        
        # If preferred player not found, use any available
        if available_players:
            name = list(available_players.keys())[0]
            return name, available_players[name]
        
        return None, None
    
    def get_file_size(self, filepath):
        """Get human readable file size"""
        try:
            size = os.path.getsize(filepath)
            for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
                if size < 1024.0:
                    return f"{size:.1f} {unit}"
                size /= 1024.0
            return f"{size:.1f} PB"
        except:
            return "Unknown"
    
    def scan_directory(self):
        """Scan current directory for video files"""
        self.print_info(f"Scanning: {self.current_dir}")
        self.files_found = []
        
        try:
            for filename in sorted(os.listdir(self.current_dir)):
                filepath = os.path.join(self.current_dir, filename)
                if os.path.isfile(filepath):
                    ext = os.path.splitext(filename)[1].lower()
                    if ext in self.video_extensions:
                        size = self.get_file_size(filepath)
                        self.files_found.append({
                            'name': filename,
                            'path': filepath,
                            'size': size,
                            'ext': ext
                        })
        except PermissionError:
            self.print_error("Permission denied accessing directory")
            return False
        except Exception as e:
            self.print_error(f"Error scanning directory: {e}")
            return False
        
        if not self.files_found:
            self.print_warning("No video files found in current directory")
            return False
        
        self.print_success(f"Found {len(self.files_found)} video file(s)")
        return True
    
    def display_files(self):
        """Display list of video files"""
        print(f"\n{Colors.BOLD}Video files in current directory:{Colors.ENDC}")
        print("-" * 70)
        
        for i, file in enumerate(self.files_found, 1):
            ext_color = Colors.OKGREEN
            print(f"  [{i:2}] {ext_color}{file['name']}{Colors.ENDC}")
            print(f"       Size: {file['size']}")
        
        print("-" * 70)
    
    def select_file(self):
        """Let user select a video file to play"""
        self.display_files()
        
        print(f"\n{Colors.OKBLUE}Enter file number to play (or 'q' to quit, 's' for settings):{Colors.ENDC} ", end="")
        
        try:
            choice = input().strip()
            
            if choice.lower() == 'q':
                return None
            
            if choice.lower() == 's':
                self.configure_player()
                return self.select_file()
            
            num = int(choice)
            if 1 <= num <= len(self.files_found):
                return self.files_found[num - 1]
            else:
                self.print_error(f"Invalid selection. Enter 1-{len(self.files_found)}")
                return self.select_file()
        except ValueError:
            self.print_error("Please enter a number, 'q', or 's'")
            return self.select_file()
    
    def configure_player(self):
        """Configure preferred video player"""
        available = self.check_players_installed()
        
        print(f"\n{Colors.BOLD}Video Player Settings{Colors.ENDC}")
        print("-" * 50)
        print(f"Current preference: {Colors.OKCYAN}{self.player_preference}{Colors.ENDC}")
        print(f"\nAvailable players:")
        
        buddy_status = f"{Colors.OKGREEN}[INSTALLED]{Colors.ENDC}" if 'buddy' in available else f"{Colors.FAIL}[NOT FOUND]{Colors.ENDC}"
        ncplayer_status = f"{Colors.OKGREEN}[INSTALLED]{Colors.ENDC}" if 'ncplayer' in available else f"{Colors.FAIL}[NOT FOUND]{Colors.ENDC}"
        
        print(f"  [1] auto - Try both (buddy first) {'[CURRENT]' if self.player_preference == 'auto' else ''}")
        print(f"  [2] buddy - Half-block/ASCII/braille {buddy_status} {'[CURRENT]' if self.player_preference == 'buddy' else ''}")
        print(f"  [3] ncplayer - notcurses player {ncplayer_status} {'[CURRENT]' if self.player_preference == 'ncplayer' else ''}")
        
        print(f"\n{Colors.OKBLUE}Select player (1-3, or Enter to cancel):{Colors.ENDC} ", end="")
        choice = input().strip()
        
        if choice == '1':
            self.save_player_preference('auto')
            self.print_success("Player set to: auto")
        elif choice == '2':
            self.save_player_preference('buddy')
            self.print_success("Player set to: buddy")
        elif choice == '3':
            self.save_player_preference('ncplayer')
            self.print_success("Player set to: ncplayer")
    
    def get_buddy_options(self):
        """Get playback options for buddy"""
        options = {
            'mode': 'half',
            'quality': 2,
            'scale': 1.0,
            'loop': False,
            'no_info': False
        }
        
        print(f"\n{Colors.BOLD}Playback Options (buddy):{Colors.ENDC}")
        print("-" * 40)
        
        # Render mode
        print(f"\n{Colors.OKCYAN}Render Mode:{Colors.ENDC}")
        print("  [1] half (default) - Best quality, Unicode half-blocks")
        print("  [2] ascii - Classic ASCII art look")
        print("  [3] braille - Highest resolution, braille patterns")
        
        mode_choice = input(f"{Colors.OKBLUE}Select mode (1-3, default=1): {Colors.ENDC}").strip()
        if mode_choice == '2':
            options['mode'] = 'ascii'
        elif mode_choice == '3':
            options['mode'] = 'braille'
        
        # Quality level
        print(f"\n{Colors.OKCYAN}Quality Level:{Colors.ENDC}")
        print("  [1] Fast - Nearest-neighbor sampling")
        print("  [2] Balanced (default) - 4-tap supersample")
        print("  [3] Best - Full box filter (highest CPU)")
        
        quality_choice = input(f"{Colors.OKBLUE}Select quality (1-3, default=2): {Colors.ENDC}").strip()
        if quality_choice == '1':
            options['quality'] = 1
        elif quality_choice == '3':
            options['quality'] = 3
        
        # Scale
        scale_input = input(f"{Colors.OKBLUE}Terminal fill scale 0.1-1.0 (default=1.0): {Colors.ENDC}").strip()
        if scale_input:
            try:
                scale = float(scale_input)
                if 0.1 <= scale <= 1.0:
                    options['scale'] = scale
            except ValueError:
                pass
        
        # Loop
        loop_choice = input(f"{Colors.OKBLUE}Loop video? (y/N): {Colors.ENDC}").strip().lower()
        options['loop'] = loop_choice in ['y', 'yes']
        
        # Hide info bar
        info_choice = input(f"{Colors.OKBLUE}Hide status bar? (y/N): {Colors.ENDC}").strip().lower()
        options['no_info'] = info_choice in ['y', 'yes']
        
        return options
    
    def play_video(self, video_file, player_name, player_path, options=None):
        """Play the video using the selected player"""
        self.print_header(f"Playing Video ({player_name})")
        
        self.print_info(f"Playing: {video_file['name']}")
        self.print_info(f"Player: {player_name}")
        
        # Build command based on player
        if player_name == 'buddy':
            cmd = [player_path, video_file['path']]
            if options:
                cmd.extend(['-m', options['mode']])
                cmd.extend(['-q', str(options['quality'])])
                cmd.extend(['-s', str(options['scale'])])
                if options['loop']:
                    cmd.append('--loop')
                if options['no_info']:
                    cmd.append('--no-info')
                self.print_info(f"Mode: {options['mode']}, Quality: {options['quality']}, Scale: {options['scale']}")
        else:  # ncplayer
            cmd = [player_path, '-k', video_file['path']]  # -k for keyboard control
        
        print(f"\n{Colors.WARNING}Press 'q' to stop playback{Colors.ENDC}\n")
        
        # Store original signal handler and ignore SIGINT in parent
        original_sigint = signal.signal(signal.SIGINT, signal.SIG_IGN)
        
        try:
            # Run player - it will receive SIGINT, parent won't
            process = subprocess.Popen(cmd, 
                preexec_fn=lambda: signal.signal(signal.SIGINT, signal.SIG_DFL))
            process.wait()
            
            signal.signal(signal.SIGINT, original_sigint)
            self.print_success("Playback complete")
            return True
        except Exception as e:
            signal.signal(signal.SIGINT, original_sigint)
            self.print_error(f"Playback error: {e}")
            return False
    
    def print_installation_help(self):
        """Print help for installing video players"""
        print(f"\n{Colors.BOLD}No video player found!{Colors.ENDC}")
        print(f"\nYou need either {Colors.OKCYAN}buddy{Colors.ENDC} or {Colors.OKCYAN}ncplayer{Colors.ENDC} (notcurses).\n")
        
        print(f"{Colors.BOLD}Option 1: Install buddy{Colors.ENDC}")
        print("-" * 50)
        print(f"{Colors.OKCYAN}GitHub: https://github.com/JVSCHANDRADITHYA/buddy{Colors.ENDC}")
        print(f"\n{Colors.WARNING}Install:{Colors.ENDC}")
        print("   # Create venv (for PEP 668 systems)")
        print("   cd /path/to/buddy && python3 -m venv venv")
        print("   venv/bin/pip install numpy imageio imageio-ffmpeg")
        print("   # Then create wrapper script (see README)")
        
        print(f"\n{Colors.BOLD}Option 2: Install ncplayer (notcurses){Colors.ENDC}")
        print("-" * 50)
        print(f"{Colors.OKCYAN}GitHub: https://github.com/dankamongmen/notcurses{Colors.ENDC}")
        print(f"\n{Colors.WARNING}Install (Debian/Ubuntu):{Colors.ENDC}")
        print("   sudo apt install notcurses-bin")
        print(f"\n{Colors.WARNING}Install (Arch):{Colors.ENDC}")
        print("   sudo pacman -S notcurses")
        print(f"\n{Colors.WARNING}Install (macOS):{Colors.ENDC}")
        print("   brew install notcurses")
        
        print()
    
    def use_quick_play(self):
        """Ask if user wants to use default options"""
        print(f"\n{Colors.OKBLUE}Use default settings? (Y/n): {Colors.ENDC}", end="")
        choice = input().strip().lower()
        return choice not in ['n', 'no']
    
    def run(self):
        """Main run method"""
        self.print_header("Video Player")
        
        # Check which players are installed
        available_players = self.check_players_installed()
        
        if not available_players:
            self.print_installation_help()
            return False
        
        # Get the player to use
        player_name, player_path = self.get_player(available_players)
        
        if not player_path:
            self.print_installation_help()
            return False
        
        self.print_success(f"Using: {player_name} ({player_path})")
        self.print_info(f"Preference: {self.player_preference}")
        
        if len(available_players) > 1:
            self.print_info("Tip: Press 's' in file selection to change player")
        
        # Scan for video files
        if not self.scan_directory():
            return False
        
        while True:
            # Select file
            selected_file = self.select_file()
            if not selected_file:
                self.print_info("Exiting video player")
                return True
            
            # Get options for buddy (ncplayer uses defaults)
            options = None
            if player_name == 'buddy':
                if self.use_quick_play():
                    options = {
                        'mode': 'half',
                        'quality': 2,
                        'scale': 1.0,
                        'loop': False,
                        'no_info': False
                    }
                else:
                    options = self.get_buddy_options()
            
            # Play the video
            self.play_video(selected_file, player_name, player_path, options)
            
            # Ask to play another
            print(f"\n{Colors.OKBLUE}Play another video? (Y/n): {Colors.ENDC}", end="")
            again = input().strip().lower()
            if again in ['n', 'no']:
                break
            
            # Re-check player in case settings changed
            player_name, player_path = self.get_player(self.check_players_installed())
        
        self.print_info("Exiting video player")
        return True


def main():
    """Entry point"""
    player = VideoPlayer()
    
    try:
        success = player.run()
        sys.exit(0 if success else 1)
    except KeyboardInterrupt:
        print(f"\n{Colors.WARNING}Interrupted by user{Colors.ENDC}")
        sys.exit(0)
    except Exception as e:
        print(f"\n{Colors.FAIL}Error: {e}{Colors.ENDC}")
        sys.exit(1)


if __name__ == "__main__":
    main()
