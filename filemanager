    def _build_ncplayer_cmd(self, ncplayer_path, filepath, options=None):
        """Build ncplayer command with options"""
        if options is None:
            # Best defaults: high-quality scale, pixel blitter, quiet
            options = {'scaling': 'scalehi', 'blitter': 'pixel', 'quiet': True}
        
        cmd = [ncplayer_path]
        if options.get('scaling'):
            cmd.extend(['-s', options['scaling']])
        if options.get('blitter'):
            cmd.extend(['-b', options['blitter']])
        if options.get('loop'):
            cmd.append('-L')
        if options.get('quiet'):
            cmd.append('-q')
        if options.get('margins'):
            cmd.extend(['-m', options['margins']])
        cmd.append(str(filepath))
        return cmd

    def _build_buddy_cmd(self, buddy_path, filepath, options=None):
        """Build buddy command with options"""
        if options is None:
            # Best defaults: half-block mode, quality 3, full scale
            options = {'mode': 'half', 'quality': 3, 'scale': 1.0}
        
        cmd = [buddy_path, str(filepath)]
        if options.get('mode'):
            cmd.extend(['-m', options['mode']])
        if options.get('quality'):
            cmd.extend(['-q', str(options['quality'])])
        if options.get('scale'):
            cmd.extend(['-s', str(options['scale'])])
        if options.get('loop'):
            cmd.append('--loop')
        if options.get('no_info'):
            cmd.append('--no-info')
        return cmd

