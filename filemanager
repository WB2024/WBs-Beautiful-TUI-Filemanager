    def play_selected_video(self):
        """Play the currently selected video file with configured video player"""
        if not self.entries or self.selected_index >= len(self.entries):
            return
        
        entry = self.entries[self.selected_index]
        
        # Check if it's a video file
        if entry['is_dir'] or not self.is_video_file(entry['path']):
            self.message = "Not a video file"
            self.message_color = curses.COLOR_YELLOW
            return
        
        # Determine which video player to use
        player_pref = self.config.video_player
        buddy_path = shutil.which('buddy')
        ncplayer_path = shutil.which('ncplayer')
        
        player_path = None
        player_name = None
        
        if player_pref == 'buddy':
            player_path = buddy_path
            player_name = 'buddy'
        elif player_pref == 'ncplayer':
            player_path = ncplayer_path
            player_name = 'ncplayer'
        else:  # auto - try ncplayer first (better quality), then buddy
            if ncplayer_path:
                player_path = ncplayer_path
                player_name = 'ncplayer'
            elif buddy_path:
                player_path = buddy_path
                player_name = 'buddy'
        
        if not player_path:
            self.message = "No video player found (install buddy or ncplayer)"
