    def bulk_delete_all(self):
        """Delete all files in current directory with progress indicator"""
        files = [e for e in self.entries if not e['is_dir'] and e['name'] != '..']
        
        if not files:
            self.message = "No files to delete"
            self.message_color = curses.COLOR_YELLOW
            return
        
        self.show_message_box(
            "DELETE ALL FILES",
            [
                f"Delete all {len(files)} file(s) in this folder?",
                "This cannot be undone.",
                "",
                "Press Y to confirm, any other key to cancel.",
            ],
            wait_for_key=False,
            style='danger',
        )
        
        key = self.stdscr.getch()
        if key not in [ord('y'), ord('Y')]:
            self.message = "Delete cancelled"
            self.message_color = curses.COLOR_YELLOW
            return
        
        # Delete files with progress
        success = 0
        failed = 0
        total_items = len(files)
        
        # Show immediate "preparing" status so UI doesn't appear frozen
        self.show_progress("DELETING ALL FILES", "Preparing...", 0, total_items)
        
        for idx, entry in enumerate(files, 1):
            # Show progress
            self.show_progress("DELETING ALL FILES", entry['name'], idx, total_items)
            
            try:
                Path(entry['path']).unlink()
                success += 1
            except:
                failed += 1
        
        # Refresh directory to show changes
        self.load_directory()
        
        # Force redraw to clear progress dialog
        self.draw()
        
        if failed == 0:
            self.message = f"Deleted {success} file(s)"
            self.message_color = curses.COLOR_GREEN
        else:
            self.message = f"Deleted: {success} ok, {failed} failed"
            self.message_color = curses.COLOR_YELLOW

