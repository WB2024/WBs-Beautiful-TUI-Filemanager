@dataclass
class KittyCapabilities:
    has_graphics: bool
    has_true_color: bool
    has_styled_underlines: bool
    cell_width_px: int
    cell_height_px: int
    is_kitty: bool


def detect_kitty():
    """Detect Kitty and related terminal capabilities."""
    try:
        term_program = os.environ.get('TERM_PROGRAM', '')
        term = os.environ.get('TERM', '')
        kitty_window_id = os.environ.get('KITTY_WINDOW_ID')
        ssh_tty = os.environ.get('SSH_TTY')
        colorterm = os.environ.get('COLORTERM', '')

        is_kitty = (
            term_program == 'kitty'
            or 'kitty' in term.lower()
            or bool(kitty_window_id)
        )

        has_true_color = colorterm.lower() == 'truecolor'
        has_graphics = is_kitty and not bool(ssh_tty)
        has_styled_underlines = is_kitty

        cell_width_px = 0
        cell_height_px = 0

        try:
            winsz = fcntl.ioctl(sys.stdout.fileno(), termios.TIOCGWINSZ, b'\x00' * 8)
            rows, cols, xpixel, ypixel = struct.unpack('HHHH', winsz)
            if cols > 0 and xpixel > 0:
                cell_width_px = xpixel // cols
            if rows > 0 and ypixel > 0:
                cell_height_px = ypixel // rows
        except Exception:
            pass

        return KittyCapabilities(
            has_graphics=has_graphics,
            has_true_color=has_true_color,
            has_styled_underlines=has_styled_underlines,
            cell_width_px=cell_width_px,
            cell_height_px=cell_height_px,
            is_kitty=is_kitty,
        )
    except Exception:
        return KittyCapabilities(
            has_graphics=False,
            has_true_color=False,
            has_styled_underlines=False,
            cell_width_px=0,
            cell_height_px=0,
            is_kitty=False,
        )


def tc_fg(r, g, b):
    return f"\x1b[38;2;{r};{g};{b}m"


def tc_bg(r, g, b):
    return f"\x1b[48;2;{r};{g};{b}m"


def tc_reset():
    return "\x1b[0m"


def tc_underline_curly(r, g, b):
    return f"\x1b[4:3m\x1b[58;2;{r};{g};{b}m"


def tc_underline_off():
    return "\x1b[4:0m\x1b[59m"


def kitty_send_image(path, x, y, cols, rows, image_id=0):
    """Transmit and display a local image file via Kitty graphics protocol."""
    try:
        abs_path = os.path.abspath(path)
        payload = base64.b64encode(abs_path.encode('utf-8')).decode('ascii')
        chunk_size = 4096

        try:
            sys.stdout.write(f"\x1b[{y+1};{x+1}H")
            sys.stdout.flush()
        except Exception:
            pass

        for i in range(0, len(payload), chunk_size):
            chunk = payload[i:i + chunk_size]
            more = 1 if i + chunk_size < len(payload) else 0
            if i == 0:
                seq = (
                    f"\x1b_Ga=T,t=f,f=100,c={cols},r={rows},C=1,z=-1,"
                    f"i={image_id},m={more};{chunk}\x1b\\"
                )
            else:
                seq = f"\x1b_Gm={more};{chunk}\x1b\\"
            try:
                sys.stdout.buffer.write(seq.encode('utf-8'))
                sys.stdout.flush()
            except (BrokenPipeError, OSError):
                return False

        return True
    except Exception:
        return False


def kitty_delete_images(image_id=None):
    """Delete Kitty images by id or delete all when id is None."""
    try:
        if image_id is None:
            seq = "\x1b_Ga=d,d=a\x1b\\"
        else:
            seq = f"\x1b_Ga=d,d=i,i={image_id}\x1b\\"
        sys.stdout.buffer.write(seq.encode('utf-8'))
        sys.stdout.flush()
        return True
    except (BrokenPipeError, OSError):
        return False
    except Exception:
        return False


def kitty_clear_image_area(x, y, cols, rows):
    """Clear a rectangular image area in Kitty, with safe fallback behavior."""
    try:
        # Kitty delete command supports per-cell intersection; clear the rectangle
        # by issuing cell deletes over the requested area.
        for yy in range(y, y + rows):
            for xx in range(x, x + cols):
                seq = f"\x1b_Ga=d,d=p,x={xx+1},y={yy+1}\x1b\\"
                sys.stdout.buffer.write(seq.encode('utf-8'))
        sys.stdout.flush()
        return True
    except (BrokenPipeError, OSError):
        return False
    except Exception:
        return False


