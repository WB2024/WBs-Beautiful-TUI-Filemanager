            tc_addstr(self.stdscr, start_y + 7, start_x + 2, f"Video Bitrate: {self.format_bitrate(info.get('video_bitrate', info.get('total_bitrate', 0)))}", fg=THEME['text_secondary'], bg=THEME['bg_surface'])
