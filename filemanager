    def draw_footer(self):
        """Draw footer with help"""
        height, width = self.stdscr.getmaxyx()
        
        # Separator
        sep = ICONS['box_h'] * width
        self.stdscr.addstr(height - 4, 0, sep[:width], curses.color_pair(14) if self.has_256_colors else 0)
        
