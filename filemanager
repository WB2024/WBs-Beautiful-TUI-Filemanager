    def toggle_mark(self):
        """Toggle mark on current file"""
        if not self.entries or self.selected_index >= len(self.entries):
            return
        
        entry = self.entries[self.selected_index]
        
        # Don't allow marking ".." directory
        if entry['name'] == '..':
            self.message = "Cannot mark parent directory"
            self.message_color = curses.COLOR_YELLOW
            return
        
        path = entry['path']
        if path in self.selected_files:
            self.selected_files.remove(path)
            self.message = f"Unmarked: {entry['name']}"
        else:
            self.selected_files.add(path)
            self.message = f"Marked: {entry['name']}"
        self.message_color = curses.COLOR_GREEN
        
        # Move to next item
        if self.selected_index < len(self.entries) - 1:
            self.selected_index += 1
    
    def mark_all_files(self):
        """Mark all files (not directories) in current directory"""
        count = 0
        for entry in self.entries:
            if not entry['is_dir'] and entry['name'] != '..':
                self.selected_files.add(entry['path'])
                count += 1
        
        self.message = f"Marked {count} files"
        self.message_color = curses.COLOR_GREEN
    
    def unmark_all_files(self):
        """Unmark all files"""
        count = len(self.selected_files)
        self.selected_files.clear()
        self.message = f"Unmarked {count} files"
        self.message_color = curses.COLOR_GREEN
    
    def copy_to_clipboard(self):
        """Copy marked files or current file to clipboard"""
        if self.selected_files:
            self.clipboard = list(self.selected_files)
            self.clipboard_operation = 'copy'
            self.message = f"Copied {len(self.clipboard)} file(s) to clipboard"
        else:
            # Copy current file
            if not self.entries or self.selected_index >= len(self.entries):
                return
            entry = self.entries[self.selected_index]
            if entry['name'] == '..':
                self.message = "Cannot copy parent directory"
                self.message_color = curses.COLOR_YELLOW
                return
            self.clipboard = [entry['path']]
            self.clipboard_operation = 'copy'
            self.message = f"Copied: {entry['name']}"
        self.message_color = curses.COLOR_GREEN
    
    def cut_to_clipboard(self):
        """Cut marked files or current file to clipboard"""
        if self.selected_files:
            self.clipboard = list(self.selected_files)
            self.clipboard_operation = 'cut'
            self.message = f"Cut {len(self.clipboard)} file(s) to clipboard"
        else:
            # Cut current file
            if not self.entries or self.selected_index >= len(self.entries):
                return
            entry = self.entries[self.selected_index]
            if entry['name'] == '..':
                self.message = "Cannot cut parent directory"
                self.message_color = curses.COLOR_YELLOW
                return
            self.clipboard = [entry['path']]
            self.clipboard_operation = 'cut'
            self.message = f"Cut: {entry['name']}"
        self.message_color = curses.COLOR_GREEN
    
    def paste_from_clipboard(self):
        """Paste files from clipboard to current directory with progress indicator"""
        if not self.clipboard:
            self.message = "Clipboard is empty"
            self.message_color = curses.COLOR_YELLOW
            return
        
        success = 0
        failed = 0
        dest_dir = self.current_dir
        total_items = len(self.clipboard)
        operation_title = "COPYING FILES" if self.clipboard_operation == 'copy' else "MOVING FILES"
        
        # Show immediate "preparing" status so UI doesn't appear frozen
        self.show_progress(operation_title, "Preparing...", 0, total_items)
        
        for idx, src_path in enumerate(self.clipboard, 1):
            src_path = Path(src_path)
            if not src_path.exists():
                failed += 1
                continue
            
            dest_path = dest_dir / src_path.name
            
            # Handle name conflicts
            if dest_path.exists():
                # Generate unique name
                base = src_path.stem
                ext = src_path.suffix
                counter = 1
                while dest_path.exists():
                    dest_path = dest_dir / f"{base}_{counter}{ext}"
                    counter += 1
            
            try:
                if self.clipboard_operation == 'copy':
                    if src_path.is_dir():
                        # Use progress-enabled directory copy
                        self.copy_tree_with_progress(src_path, dest_path, idx, total_items, operation_title)
                    else:
                        # Use progress-enabled file copy
                        self.copy_file_with_progress(src_path, dest_path, idx, total_items, operation_title)
                else:  # cut/move
                    # Show progress for move operation
                    self.show_progress(operation_title, src_path.name, idx, total_items)
                    shutil.move(str(src_path), str(dest_path))
                success += 1
            except Exception as e:
                failed += 1
        
        # Save operation type for message before clearing
        was_copy = self.clipboard_operation == 'copy'
        
        # Clear clipboard after cut operation
        if self.clipboard_operation == 'cut':
            self.clipboard = []
            self.clipboard_operation = None
        
        # Clear selections
        self.selected_files.clear()
        
        # Refresh directory to show changes
        self.load_directory()
        
        # Force redraw to clear progress dialog
        self.draw()
        
        if failed == 0:
            op = "Copied" if was_copy else "Moved"
            self.message = f"{op} {success} file(s)"
            self.message_color = curses.COLOR_GREEN
        else:
            self.message = f"Completed: {success} ok, {failed} failed"
            self.message_color = curses.COLOR_YELLOW
    
    def delete_files(self):
        """Delete marked files or current file with progress indicator"""
        # Determine what to delete
        if self.selected_files:
            files_to_delete = list(self.selected_files)
            confirm_title = "DELETE FILES"
            confirm_lines = [
                f"Delete {len(files_to_delete)} marked file(s)?",
                "This cannot be undone.",
                "",
                "Press Y to confirm, any other key to cancel.",
            ]
        else:
            if not self.entries or self.selected_index >= len(self.entries):
                return
            entry = self.entries[self.selected_index]
            if entry['name'] == '..':
                self.message = "Cannot delete parent directory"
                self.message_color = curses.COLOR_YELLOW
                return
            files_to_delete = [entry['path']]
            confirm_title = "DELETE FILE"
            confirm_lines = [
                f"Delete '{entry['name']}'?",
                "This cannot be undone.",
                "",
                "Press Y to confirm, any other key to cancel.",
            ]

        self.show_message_box(confirm_title, confirm_lines, wait_for_key=False, style='danger')
        
        key = self.stdscr.getch()
        if key not in [ord('y'), ord('Y')]:
            self.message = "Delete cancelled"
            self.message_color = curses.COLOR_YELLOW
            return
        
        # Perform deletion with progress
        success = 0
        failed = 0
        total_items = len(files_to_delete)
        
        # Show immediate "preparing" status so UI doesn't appear frozen
        self.show_progress("DELETING FILES", "Preparing...", 0, total_items)
        
        for idx, path in enumerate(files_to_delete, 1):
            path = Path(path)
            
            # Show progress
            self.show_progress("DELETING FILES", path.name, idx, total_items)
            
            try:
                if path.is_dir():
                    shutil.rmtree(path)
                else:
                    path.unlink()
                success += 1
            except Exception as e:
                failed += 1
        
        # Clear selections
        self.selected_files.clear()
        
        # Refresh directory to show changes
        self.load_directory()
        
        # Force redraw to clear progress dialog
        self.draw()
        
        if failed == 0:
            self.message = f"Deleted {success} item(s)"
            self.message_color = curses.COLOR_GREEN
        else:
            self.message = f"Deleted: {success} ok, {failed} failed"
            self.message_color = curses.COLOR_YELLOW
    
    def get_text_input(self, prompt, default=""):
        """Get text input from user"""
        height, width = self.stdscr.getmaxyx()
        
        # Enable cursor
        curses.curs_set(1)
        curses.echo()
        
        # Clear message line and show prompt
        self.stdscr.addstr(height - 1, 1, " " * (width - 2))
        self.stdscr.addstr(height - 1, 1, prompt[:width-2])
        self.stdscr.refresh()
        
        # Position cursor after prompt
        input_x = len(prompt) + 2
        if input_x >= width - 1:
            input_x = 1
        
        # Create input window
        try:
            input_str = ""
            if default:
                input_str = default
                self.stdscr.addstr(height - 1, input_x, default[:width-input_x-1])
            
            while True:
                key = self.stdscr.getch()
                
                if key in [ord('\n'), curses.KEY_ENTER, 10, 13]:
                    break
                elif key == 27:  # Escape
                    input_str = ""
                    break
                elif key in [curses.KEY_BACKSPACE, 127, 8]:
                    if input_str:
                        input_str = input_str[:-1]
                        self.stdscr.addstr(height - 1, input_x, input_str + " ")
                        self.stdscr.move(height - 1, input_x + len(input_str))
                elif 32 <= key <= 126:  # Printable characters
                    if input_x + len(input_str) < width - 2:
                        input_str += chr(key)
                        self.stdscr.addch(height - 1, input_x + len(input_str) - 1, key)
                
                self.stdscr.refresh()
        finally:
            curses.noecho()
            curses.curs_set(0)
        
        return input_str.strip()
    
