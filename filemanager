    def copy_file_with_progress(self, src_path, dest_path, item_num, total_items, operation_title):
        """Copy a file with progress indicator for large files"""
        src_path = Path(src_path)
        dest_path = Path(dest_path)
        
        # Get file size
        file_size = src_path.stat().st_size
        
        # For small files (< 10MB), use simple copy
        if file_size < 10 * 1024 * 1024:
            self.show_progress(operation_title, src_path.name, item_num, total_items)
            if src_path.is_dir():
                shutil.copytree(src_path, dest_path)
            else:
                shutil.copy2(src_path, dest_path)
            return
        
        # For large files, copy in chunks with progress
        # Use smaller chunks for better progress granularity
        chunk_size = 512 * 1024  # 512KB chunks for smoother progress
        bytes_copied = 0
        chunks_written = 0
        
        # Show initial progress (0%)
        self.show_progress(
            operation_title,
            src_path.name,
            item_num,
            total_items,
            0,
            file_size
        )
        
        with open(src_path, 'rb') as src_file:
            with open(dest_path, 'wb') as dest_file:
                while True:
                    chunk = src_file.read(chunk_size)
                    if not chunk:
                        break
                    dest_file.write(chunk)
                    bytes_copied += len(chunk)
                    chunks_written += 1
                    
                    # Flush to disk every 4MB to ensure actual I/O progress
                    if chunks_written % 8 == 0:
                        dest_file.flush()
                        os.fsync(dest_file.fileno())
                    
                    # Update progress display
                    self.show_progress(
                        operation_title,
                        src_path.name,
                        item_num,
                        total_items,
                        bytes_copied,
                        file_size
                    )
                
                # Final flush
                dest_file.flush()
                os.fsync(dest_file.fileno())
        
        # Copy file metadata
        shutil.copystat(src_path, dest_path)
    
    def copy_tree_with_progress(self, src_path, dest_path, item_num, total_items, operation_title):
        """Copy a directory tree with progress"""
        src_path = Path(src_path)
        dest_path = Path(dest_path)
        
        # Count total files first
        total_files = sum(1 for _ in src_path.rglob('*') if _.is_file())
        current_file = 0
        
        # Create destination directory
        dest_path.mkdir(parents=True, exist_ok=True)
        
        # Copy all files
        for src_file in src_path.rglob('*'):
            rel_path = src_file.relative_to(src_path)
            dest_file = dest_path / rel_path
            
            if src_file.is_dir():
                dest_file.mkdir(parents=True, exist_ok=True)
            else:
                current_file += 1
                # Ensure parent directory exists
                dest_file.parent.mkdir(parents=True, exist_ok=True)
                
                # Update progress display
                progress_name = f"{src_path.name}/{rel_path}" if len(str(rel_path)) < 30 else src_file.name
                self.show_progress(
                    operation_title,
                    f"[{current_file}/{total_files}] {progress_name}",
                    item_num,
                    total_items
                )
                
                # Copy file with progress for large files
                file_size = src_file.stat().st_size
                if file_size > 10 * 1024 * 1024:  # > 10MB
                    self.copy_file_with_progress(src_file, dest_file, item_num, total_items, operation_title)
                else:
                    shutil.copy2(src_file, dest_file)
        
        # Copy directory metadata
        shutil.copystat(src_path, dest_path)
    
