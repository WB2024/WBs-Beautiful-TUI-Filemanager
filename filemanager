    def configure_video_player(self):
        """Show menu to configure preferred video player"""
        height, width = self.stdscr.getmaxyx()
        
        # Check which players are available
        buddy_available = shutil.which('buddy') is not None
        ncplayer_available = shutil.which('ncplayer') is not None
        current = self.config.video_player
        
        menu_items = [
            ("1", f"Auto (try both) {'[CURRENT]' if current == 'auto' else ''}", "auto"),
            ("2", f"buddy (half-block/ASCII/braille) {'[CURRENT]' if current == 'buddy' else ''} {'[INSTALLED]' if buddy_available else '[NOT FOUND]'}", "buddy"),
            ("3", f"ncplayer (notcurses) {'[CURRENT]' if current == 'ncplayer' else ''} {'[INSTALLED]' if ncplayer_available else '[NOT FOUND]'}", "ncplayer"),
        ]
        
        # Draw menu
        menu_width = 55
        menu_height = len(menu_items) + 6
        start_y = (height - menu_height) // 2
        start_x = (width - menu_width) // 2
        
        # Draw box
        self.stdscr.attron(curses.color_pair(7))
        self.stdscr.addstr(start_y, start_x, "+" + "-" * (menu_width - 2) + "+")
        self.stdscr.addstr(start_y + 1, start_x, "|" + " VIDEO PLAYER SETTINGS ".center(menu_width - 2) + "|")
        self.stdscr.addstr(start_y + 2, start_x, "+" + "-" * (menu_width - 2) + "+")
        self.stdscr.attroff(curses.color_pair(7))
        
        for i, (key, label, action) in enumerate(menu_items):
            y = start_y + 3 + i
            self.stdscr.addstr(y, start_x, "|", curses.color_pair(7))
            menu_text = f"[{key}] {label}"[:menu_width-4]
            self.stdscr.addstr(y, start_x + 1, " " * (menu_width - 2), curses.color_pair(7))
            self.stdscr.addstr(y, start_x + 2, menu_text, curses.color_pair(13) | curses.A_BOLD)
            self.stdscr.addstr(y, start_x + menu_width - 1, "|", curses.color_pair(7))
        
        self.stdscr.attron(curses.color_pair(7))
        self.stdscr.addstr(start_y + 3 + len(menu_items), start_x, "+" + "-" * (menu_width - 2) + "+")
        self.stdscr.addstr(start_y + 4 + len(menu_items), start_x, "|" + " [q] Cancel ".center(menu_width - 2) + "|")
        self.stdscr.addstr(start_y + 5 + len(menu_items), start_x, "+" + "-" * (menu_width - 2) + "+")
        self.stdscr.attroff(curses.color_pair(7))
        
        self.stdscr.refresh()
        
        # Get selection
        key = self.stdscr.getch()
        
        if key == ord('1'):
            self.config.set_video_player('auto')
            self.message = "Video player set to: auto"
            self.message_color = curses.COLOR_GREEN
        elif key == ord('2'):
            self.config.set_video_player('buddy')
            self.message = "Video player set to: buddy"
            self.message_color = curses.COLOR_GREEN
        elif key == ord('3'):
            self.config.set_video_player('ncplayer')
            self.message = "Video player set to: ncplayer"
            self.message_color = curses.COLOR_GREEN

    def _restore_curses(self):
        """Restore curses after running an external tool"""
        # Ensure terminal is in a sane state before curses takes over
        import sys
        sys.stdout.write('\x1b[?1049l')  # Leave alternate screen if stuck
        sys.stdout.write('\x1b[?25h')    # Show cursor
        sys.stdout.write('\x1b[?1000l')  # Disable mouse tracking modes
        sys.stdout.write('\x1b[?1002l')
        sys.stdout.write('\x1b[?1003l')
        sys.stdout.write('\x1b[?1006l')
        sys.stdout.flush()
        self.stdscr = curses.initscr()
        curses.start_color()
        curses.use_default_colors()
        curses.noecho()
        curses.cbreak()
        curses.curs_set(0)
        self.stdscr.keypad(True)
        curses.halfdelay(5)
        self.has_256_colors = curses.COLORS >= 256 and curses.can_change_color()
        if self.has_256_colors:
            _setup_256_colors()
        else:
            _setup_basic_colors()

