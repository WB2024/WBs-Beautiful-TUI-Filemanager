    def analyze_directory_contents(self, path):
        """Analyze directory contents - count files by type and get total size"""
        file_types = defaultdict(int)
        file_type_sizes = defaultdict(int)
        total_files = 0
        total_size = 0
        
        try:
            for item in path.rglob('*'):
                if item.is_file():
                    total_files += 1
                    try:
                        size = item.stat().st_size
                        total_size += size
                        
                        file_type = self.get_file_type_category(item)
                        file_types[file_type] += 1
                        file_type_sizes[file_type] += size
                    except:
                        pass
        except:
            pass
        
        return {
            'total_files': total_files,
            'total_size': total_size,
            'file_types': dict(file_types),
            'file_type_sizes': dict(file_type_sizes)
        }
    
    def get_directory_file_list(self, path, max_depth=3):
        """Get a hierarchical list of files in directory"""
        files_by_type = defaultdict(list)
        
        try:
            for item in path.rglob('*'):
                if item.is_file():
                    # Calculate relative path
                    try:
                        rel_path = item.relative_to(path)
                        depth = len(rel_path.parts) - 1
                        
                        if depth <= max_depth:
                            file_type = self.get_file_type_category(item)
                            size = item.stat().st_size
                            
                            files_by_type[file_type].append({
                                'name': item.name,
                                'path': str(rel_path),
                                'size': size
                            })
                    except:
                        pass
        except:
            pass
        
        return dict(files_by_type)
    
    def load_directory(self):
        """Load current directory contents"""
        self.entries = []
        self.selected_files.clear()  # Clear selections when changing directories
        
        # Add parent directory entry if not at root
        if self.current_dir != self.current_dir.parent:
            self.entries.append({
                'name': '..',
                'path': self.current_dir.parent,
                'is_dir': True,
                'size': 0,
                'perms': ''
            })
        
        try:
            items = list(self.current_dir.iterdir())
            
            # Separate and sort directories and files
            dirs = sorted([e for e in items if e.is_dir()], key=lambda x: x.name.lower())
            files = sorted([e for e in items if e.is_file()], key=lambda x: x.name.lower())
            
            # Add directories
            for d in dirs:
                self.entries.append({
                    'name': d.name,
                    'path': d,
                    'is_dir': True,
                    'size': 0,
                    'perms': self.get_permissions_string(d)
                })
            
            # Add files
            for f in files:
                try:
                    size = f.stat().st_size
                except:
                    size = 0
                
                self.entries.append({
                    'name': f.name,
                    'path': f,
                    'is_dir': False,
                    'size': size,
                    'perms': self.get_permissions_string(f)
                })
        
        except PermissionError:
            self.message = "Permission denied reading directory"
            self.message_color = curses.COLOR_RED
        
        # Reset selection if out of bounds
        if self.selected_index >= len(self.entries):
            self.selected_index = max(0, len(self.entries) - 1)

        self._detect_git_info()
        self._tree_dirty = True
        self._needs_redraw = True
        # Invalidate preview cache on directory change
        self.preview_cache = {'path': None, 'content': None, 'image_id': 0}

    def _build_tree(self, force=False):
        """Build a flat, renderable directory tree rooted at the user's home."""
        if not force and not self._tree_dirty:
            return
        self._tree_dirty = False
        try:
            home = Path.home().resolve()
        except (OSError, RuntimeError):
            self._tree_items = []
            return
        max_depth = 3
        tree_items = []

        def list_subdirs(path):
            try:
                children = [
                    p for p in path.iterdir()
                    if p.is_dir() and not p.name.startswith('.')
                ]
                return sorted(children, key=lambda d: d.name.lower())
            except (PermissionError, OSError):
                return []

        def walk(path, depth, parent_has_more, is_last):
            try:
                path_key = str(path.resolve())
            except (OSError, RuntimeError):
                return
            is_expanded = bool(self.tree_expanded.get(path_key, False))

            prefix_parts = []
            for has_more in parent_has_more:
                prefix_parts.append('│ ' if has_more else '  ')
            if depth == 0:
                tree_prefix = ''
            else:
                tree_prefix = ''.join(prefix_parts) + ('└─' if is_last else '├─')

            item = {
                'type': 'dir',
                'path': path,
                'name': f"{path.name}/" if depth > 0 else f"{home.name}/",
                'depth': depth,
                'is_expanded': is_expanded,
                'is_last': is_last,
                'tree_prefix': tree_prefix,
            }
            tree_items.append(item)

            if not is_expanded or depth >= max_depth:
                return

            children = list_subdirs(path)
            child_count = len(children)
            for idx, child in enumerate(children):
                child_is_last = (idx == child_count - 1)
                walk(child, depth + 1, parent_has_more + [not child_is_last], child_is_last)

        walk(home, 0, [], True)
        self._tree_items = tree_items

    def _detect_git_info(self):
        """Detect git branch and dirty status for current directory. Cached per directory."""
        if self._git_dir_path == str(self.current_dir):
            return
        self._git_dir_path = str(self.current_dir)
        self._git_branch = None
        self._git_is_dirty = False
        self._git_status = {}
        self._git_root = None
        try:
            # Quick check - skip if git is not available
            if not shutil.which('git'):
                return
            # Combine rev-parse checks into one call
            result = subprocess.run(
                ['git', 'rev-parse', '--is-inside-work-tree', '--show-toplevel'],
                capture_output=True, text=True, timeout=2,
                cwd=str(self.current_dir)
            )
            if result.returncode != 0:
                return
            
            lines_out = result.stdout.strip().splitlines()
            if len(lines_out) >= 2 and lines_out[1].strip():
                self._git_root = Path(lines_out[1].strip())

            # Get branch and status in two calls
            branch = subprocess.run(
                ['git', 'branch', '--show-current'],
                capture_output=True, text=True, timeout=2,
                cwd=str(self.current_dir)
            )
            self._git_branch = branch.stdout.strip() or 'HEAD'

            status = subprocess.run(
                ['git', 'status', '--porcelain=v1'],
                capture_output=True, text=True, timeout=2,
                cwd=str(self.current_dir)
            )
            self._git_is_dirty = bool(status.stdout.strip())

            for line in status.stdout.splitlines():
                if len(line) < 3:
                    continue

                xy = line[:2]
                path_part = line[3:].strip()
                if not path_part or xy == '!!':
                    continue

                # Rename/copy entries use "old -> new"; track the destination path.
                if ' -> ' in path_part:
                    path_part = path_part.split(' -> ', 1)[1].strip()

                # Handle quoted porcelain paths with escaped quotes/backslashes.
                if len(path_part) >= 2 and path_part[0] == '"' and path_part[-1] == '"':
                    path_part = path_part[1:-1].replace('\\"', '"').replace('\\\\', '\\')

                path_part = path_part.replace('\\', '/').lstrip('./')
                if not path_part:
                    continue

                if xy[0] == '?' or xy[1] == '?':
                    mapped = 'untracked'
                elif xy[0] == 'M' or xy[1] == 'M':
                    mapped = 'modified'
                elif xy[0] == 'A':
                    mapped = 'added'
                elif xy[0] == 'D' or xy[1] == 'D':
                    mapped = 'deleted'
                elif xy[0] == 'R' or xy[1] == 'R':
                    mapped = 'renamed'
                else:
                    continue

                self._git_status[path_part] = mapped
        except Exception:
            pass

    def _calc_layout(self):
        """Calculate panel dimensions based on terminal size and visibility toggles."""
        height, width = self.stdscr.getmaxyx()

        # Return cached layout if terminal size and panel toggles haven't changed
        current_size = (height, width)
        current_panels = (self.show_sidebar, self.show_preview)
        if (self._cached_layout is not None
                and self._cached_layout_size == current_size
                and self._cached_layout_panels == current_panels):
            return self._cached_layout

        compact_mode = height < 20
        header_rows = 2 if compact_mode else 3
        footer_rows = 1 if compact_mode else 3
        content_height = max(1, height - header_rows - footer_rows)

        # Determine panel widths based on terminal width and toggles
        sidebar_width = 0
        preview_width = 0

        if width >= 100:
            # Full 3-panel layout.
            if self.show_sidebar:
                sidebar_width = min(30, max(18, width // 5))
            if self.show_preview:
                preview_width = min(45, max(25, int(width * 0.30)))
        elif width >= 60:
            # Mid layout: only one secondary panel fits (sidebar OR preview).
            preferred_panel = None
            if self.show_sidebar and not self.show_preview:
                preferred_panel = 'sidebar'
            elif self.show_preview and not self.show_sidebar:
                preferred_panel = 'preview'
            elif self.show_sidebar and self.show_preview:
                preferred_panel = 'sidebar' if self.active_panel == 'sidebar' else 'preview'

            if preferred_panel == 'sidebar':
                sidebar_width = min(30, max(18, width // 4))
            elif preferred_panel == 'preview':
                preview_width = min(45, max(25, int(width * 0.35)))

        # File list gets remaining space (minimum 30 cols)
        file_list_width = width - sidebar_width - preview_width
        if width >= 60 and file_list_width < 30:
            # Not enough space - hide panels
            if preview_width > 0 and sidebar_width > 0:
                preview_width = 0
                file_list_width = width - sidebar_width
            if file_list_width < 30:
                sidebar_width = 0
                preview_width = 0
                file_list_width = width
        elif width < 60:
            sidebar_width = 0
            preview_width = 0
            file_list_width = width

        result = {
            'width': width,
            'height': height,
            'compact_mode': compact_mode,
            'header_rows': header_rows,
            'footer_rows': footer_rows,
            'content_height': content_height,
            'content_start_y': header_rows,
            'sidebar_x': 0,
            'sidebar_width': sidebar_width,
            'files_x': sidebar_width,
            'files_width': file_list_width,
            'preview_x': sidebar_width + file_list_width,
            'preview_width': preview_width,
            'footer_y': height - footer_rows,
        }
        self._cached_layout = result
        self._cached_layout_size = current_size
        self._cached_layout_panels = current_panels
        return result
    
    def draw_header(self, layout):
        """Draw the 3-row header: title/breadcrumb, column headers, separator."""
        width = layout['width']
        files_x = layout['files_x']
        files_w = layout['files_width']
        preview_x = layout['preview_x']
        preview_w = layout['preview_width']

        dir_count = sum(1 for e in self.entries if e['is_dir'] and e['name'] != '..')
        file_count = sum(1 for e in self.entries if not e['is_dir'])
        git_dirty = '*' if self._git_is_dirty else ''
        git_info = f"{ICONS['git']} {self._git_branch}{git_dirty}" if self._git_branch else ""
        count_info = f"{ICONS['folder_closed']} {dir_count}  {ICONS['file_default']} {file_count}"
        right_info = f"{git_info}  {count_info}".strip()

        app_icon = ICONS['folder_open'] or ICONS['folder_closed'] or '*'
        title = f"  {app_icon} FILE MANAGER"

        home = str(Path.home())
        cur = str(self.current_dir)
        if cur.startswith(home):
            rel = cur[len(home):].strip('/')
            parts = rel.split('/') if rel else []
            breadcrumb_parts = ['~'] + [p for p in parts if p]
        else:
            breadcrumb_parts = [p for p in self.current_dir.parts if p and p != '/']
            if self.current_dir.is_absolute():
                breadcrumb_parts = ['/'] + breadcrumb_parts

        sep = " ▸ "
        breadcrumb = "  " + sep.join(breadcrumb_parts)

        if layout['header_rows'] == 2:
            compact_line = breadcrumb[:max(0, width - 1)]
            if self.use_true_color:
                tc_addstr(self.stdscr, 0, 0, ' ' * width, bg=THEME['gradient_header_2'])
                tc_addstr(self.stdscr, 0, 0, compact_line, fg=THEME['text_primary'], bg=THEME['gradient_header_2'], bold=True)
                tc_addstr(self.stdscr, 1, 0, '─' * width, fg=THEME['border_subtle'])
            else:
                self.stdscr.addstr(0, 0, ' ' * width, curses.color_pair(15))
                self.stdscr.addstr(0, 0, compact_line, curses.color_pair(17) | curses.A_BOLD)
                self.stdscr.addstr(1, 0, ('─' * width)[:width], curses.color_pair(14))
            return

        # Row 0: title bar + breadcrumb + right-aligned git/counts
        if self.use_true_color:
            tc_addstr(self.stdscr, 0, 0, ' ' * width, bg=THEME['gradient_header_2'])
            tc_addstr(self.stdscr, 0, 0, title[:width], fg=(255, 255, 255), bg=THEME['gradient_header_2'], bold=True)

            right_x = max(0, width - len(right_info) - 1)
            crumb_start = min(width - 1, len(title) + 1)
            crumb_space = max(0, right_x - crumb_start - 1)
            crumb_text = breadcrumb[:crumb_space]
            tc_addstr(self.stdscr, 0, crumb_start, crumb_text, fg=THEME['text_secondary'], bg=THEME['gradient_header_2'])

            if breadcrumb_parts:
                prefix = "  " + sep.join(breadcrumb_parts[:-1])
                if breadcrumb_parts[:-1]:
                    prefix += sep
                last_x = crumb_start + min(len(crumb_text), len(prefix))
                last_seg = breadcrumb_parts[-1][:max(0, crumb_space - len(prefix))]
                if last_seg:
                    tc_addstr(self.stdscr, 0, last_x, last_seg, fg=THEME['accent_primary'], bg=THEME['gradient_header_2'], bold=True)

            if right_info:
                tc_addstr(self.stdscr, 0, right_x, right_info[:width - right_x], fg=THEME['text_primary'], bg=THEME['gradient_header_2'], bold=True)
        else:
            self.stdscr.addstr(0, 0, ' ' * width, curses.color_pair(15))
            self.stdscr.addstr(0, 0, title[:width], curses.color_pair(17) | curses.A_BOLD)
            right_x = max(0, width - len(right_info) - 1)
            crumb_start = min(width - 1, len(title) + 1)
