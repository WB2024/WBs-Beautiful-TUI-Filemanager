# ── Dynamic curses color pair allocation ──────────────────────────────
# Pre-allocates THEME colors at startup; runtime is just dict lookups.
_tc_color_cache = {}    # RGB tuple → curses color slot
_tc_pair_cache = {}     # (fg_slot, bg_slot) → curses pair number
_tc_next_color_slot = 76   # Slots 16-75 are used by _setup_256_colors
_tc_next_pair_num = 91     # Pairs 1-90 are used by _setup_256_colors
_tc_max_color_slot = 254
_tc_max_pair_num = 255
_tc_can_remap = False   # Set once at init


def _tc_init():
    """Call once after curses.start_color(). Pre-allocates all THEME colors."""
    global _tc_max_pair_num, _tc_can_remap
    try:
        _tc_max_pair_num = min(curses.COLOR_PAIRS - 1, 32000)
    except Exception:
        _tc_max_pair_num = 255
    _tc_can_remap = curses.COLORS >= 256 and curses.can_change_color()
    if not _tc_can_remap:
        return
    # Pre-allocate every THEME color and common pairs
    for rgb in THEME.values():
        if isinstance(rgb, tuple) and len(rgb) == 3:
            _tc_get_slot(rgb)
    # Pre-allocate common fg/bg pairs
    all_colors = [v for v in THEME.values() if isinstance(v, tuple) and len(v) == 3]
    common_bgs = [THEME.get(k) for k in ('bg_base', 'bg_surface', 'bg_overlay', 'bg_selection_accent',
                                           'mark_bg', 'gradient_sel_1', 'gradient_sel_2',
                                           'gradient_header_2', 'shadow') if k in THEME]
    for fg_rgb in all_colors:
        fg_s = _tc_get_slot(fg_rgb)
        if fg_s < 0:
            continue
        for bg_rgb in common_bgs:
            bg_s = _tc_get_slot(bg_rgb)
            if bg_s >= 0:
                _tc_get_pair(fg_s, bg_s)
        _tc_get_pair(fg_s, -1)  # default bg


def _tc_quantize(rgb, step=8):
    """Round RGB components to reduce unique color count."""
    return (min(255, (rgb[0] // step) * step),
            min(255, (rgb[1] // step) * step),
            min(255, (rgb[2] // step) * step))


def _tc_get_slot(rgb):
    """Get or allocate a curses color slot for an RGB tuple."""
    global _tc_next_color_slot
    q = _tc_quantize(rgb)
    slot = _tc_color_cache.get(q)
    if slot is not None:
        return slot
    if _tc_next_color_slot > _tc_max_color_slot:
        return -1
    slot = _tc_next_color_slot
    _tc_next_color_slot += 1
    try:
        curses.init_color(slot, q[0] * 1000 // 255, q[1] * 1000 // 255, q[2] * 1000 // 255)
    except curses.error:
        return -1
    _tc_color_cache[q] = slot
    return slot


def _tc_get_pair(fg_slot, bg_slot):
    """Get or allocate a curses color pair for fg/bg slot combo."""
    global _tc_next_pair_num
    key = (fg_slot, bg_slot)
    pair = _tc_pair_cache.get(key)
    if pair is not None:
        return pair
    if _tc_next_pair_num >= _tc_max_pair_num:
        return 0
    pair = _tc_next_pair_num
    _tc_next_pair_num += 1
    try:
        curses.init_pair(pair, fg_slot, bg_slot)
    except curses.error:
        return 0
    _tc_pair_cache[key] = pair
    return pair


_tc_attr_cache = {}  # (fg, bg, bold, dim) → curses attr

def _tc_attr(fg=None, bg=None, bold=False, dim=False):
    """Build a curses attr from RGB tuples. Fast path for pre-allocated colors."""
    cache_key = (fg, bg, bold, dim)
    cached = _tc_attr_cache.get(cache_key)
    if cached is not None:
        return cached
    fg_slot = _tc_get_slot(fg) if (fg and _tc_can_remap) else -1
    bg_slot = _tc_get_slot(bg) if (bg and _tc_can_remap) else -1
    pair_num = _tc_get_pair(fg_slot, bg_slot)
    attr = curses.color_pair(pair_num)
    if bold:
        attr |= curses.A_BOLD
    if dim:
        attr |= curses.A_DIM
    _tc_attr_cache[cache_key] = attr
    return attr


def tc_addstr(stdscr, y, x, text, fg=None, bg=None, bold=False, dim=False):
    """Write text with true-color-like rendering through curses' buffer."""
    try:
        stdscr.addstr(y, x, text, _tc_attr(fg, bg, bold, dim))
    except curses.error:
        pass


