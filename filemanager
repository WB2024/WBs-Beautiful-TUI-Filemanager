            self.stdscr.addstr(0, crumb_start, breadcrumb[:crumb_space], curses.color_pair(14))
            if right_info:
                self.stdscr.addstr(0, right_x, right_info[:width - right_x], curses.color_pair(11) | curses.A_BOLD)

        # Row 1: panel-aware column headers
        if self.use_true_color:
            tc_addstr(self.stdscr, 1, 0, ' ' * width, bg=THEME['bg_surface'])
            if files_w > 0:
                name_w = max(8, files_w - 27)
                hdr = f"  {'NAME':<{name_w}} {'PERMS':<10} {'SIZE':>10}"
                tc_addstr(self.stdscr, 1, files_x, hdr[:files_w], fg=THEME['text_dim'], bg=THEME['bg_surface'])
            if preview_w > 0:
                pv = 'PREVIEW'
                pv_x = preview_x + max(0, (preview_w - len(pv)) // 2)
                tc_addstr(self.stdscr, 1, pv_x, pv[:preview_w], fg=THEME['text_dim'], bg=THEME['bg_surface'])
        else:
            self.stdscr.addstr(1, 0, ' ' * width, curses.color_pair(14))
            if files_w > 0:
                name_w = max(8, files_w - 27)
                hdr = f"  {'NAME':<{name_w}} {'PERMS':<10} {'SIZE':>10}"
                self.stdscr.addstr(1, files_x, hdr[:files_w], curses.color_pair(14))
            if preview_w > 0:
                pv = 'PREVIEW'
                pv_x = preview_x + max(0, (preview_w - len(pv)) // 2)
                self.stdscr.addstr(1, pv_x, pv[:preview_w], curses.color_pair(14))

        # Row 2: separator with panel junctions
        sep_chars = ['─'] * width
        if layout['sidebar_width'] > 0:
            bx = layout['sidebar_x'] + layout['sidebar_width']
            if 0 <= bx < width:
                sep_chars[bx] = '┬'
        if layout['preview_width'] > 0:
            bx = layout['preview_x']
            if 0 <= bx < width:
                sep_chars[bx] = '┬'
