        vbitrate = info.get('video_bitrate', info.get('total_bitrate', 0))
        br_display = self.format_bitrate(vbitrate)
        
        # Add source indicator (ASCII for terminal compatibility)
        source = info.get('video_bitrate_source', 'unknown')
