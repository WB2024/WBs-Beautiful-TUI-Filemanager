# Configuration file for bookmarks
CONFIG_FILE = Path.home() / '.filemanager_config.json'


class Config:
    """Handle configuration and bookmarks"""
    
    def __init__(self):
        self.bookmarks = {}
        self.video_player = 'auto'  # 'buddy', 'ncplayer', or 'auto'
        self.load()
    
    def load(self):
        """Load configuration from file"""
        if CONFIG_FILE.exists():
            try:
                with open(CONFIG_FILE, 'r') as f:
                    data = json.load(f)
                    self.bookmarks = data.get('bookmarks', {})
                    self.video_player = data.get('video_player', 'auto')
            except:
                self.bookmarks = {}
                self.video_player = 'auto'
    
    def save(self):
        """Save configuration to file"""
        try:
            with open(CONFIG_FILE, 'w') as f:
                json.dump({
                    'bookmarks': self.bookmarks,
                    'video_player': self.video_player
                }, f, indent=2)
        except:
            pass
    
    def set_video_player(self, player):
        """Set preferred video player (buddy, ncplayer, or auto)"""
        if player in ('buddy', 'ncplayer', 'auto'):
            self.video_player = player
            self.save()
            return True
        return False
    
    def add_bookmark(self, name, path):
        """Add a bookmark"""
        self.bookmarks[name] = str(path)
        self.save()
    
    def remove_bookmark(self, name):
        """Remove a bookmark"""
        if name in self.bookmarks:
            del self.bookmarks[name]
            self.save()
    
    def get_bookmarks(self):
        """Get all bookmarks"""
        return self.bookmarks


