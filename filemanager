                    ]
                    
                    self.show_message_box("DELETE ALL EMPTY", confirm_lines, wait_for_key=False)
                    confirm_key = self.stdscr.getch()
                    
                    if confirm_key in [ord('y'), ord('Y')]:
                        deleted_count = 0
                        error_count = 0
                        total_to_delete = len(empty)
                        
                        for idx, folder in enumerate(list(empty), 1):
                            # Show progress
                            self.show_progress("DELETING EMPTY FOLDERS", folder['name'], idx, total_to_delete)
                            
                            try:
                                shutil.rmtree(folder['path'])
                                deleted_count += 1
                                marked_folders.discard(folder['path'])
                                all_folders.remove(folder)
                                empty.remove(folder)
                            except Exception as e:
                                error_count += 1
                        
                        self.message = f"Deleted {deleted_count} empty folder(s)"
                        if error_count:
                            self.message += f", {error_count} error(s)"
                        self.message_color = curses.COLOR_GREEN if error_count == 0 else curses.COLOR_YELLOW
                        
                        # Adjust selection
                        if selected >= len(all_folders):
                            selected = max(0, len(all_folders) - 1)
                        if not all_folders:
                            self.load_directory()
                            break
                else:
                    self.show_message_box("NO EMPTY FOLDERS", ["No empty folders to delete"])
            elif key == ord('N'):
                # Delete ALL near-empty folders
                if near_empty:
                    confirm_lines = [
                        f"Delete ALL {len(near_empty)} near-empty folder(s)?",
                        "",
                        "These folders contain files < 10MB each!",
                        "This cannot be undone!",
                        "",
                        "Press 'y' to confirm, any other key to cancel"
                    ]
                    
                    self.show_message_box("DELETE ALL NEAR-EMPTY", confirm_lines, wait_for_key=False)
