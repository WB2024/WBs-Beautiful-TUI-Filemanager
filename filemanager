    def view_selected_image(self):
        """View images in current directory using pixel-index (pi)"""
        pi_path = shutil.which('pi')
        if not pi_path:
            self.message = "pixel-index (pi) not found - install with: npm install -g pixel-index"
            self.message_color = curses.COLOR_RED
            return
        
        # Exit curses temporarily
        curses.endwin()
        
        try:
            # pixel-index launches its own TUI browser in the current directory
            # Q or Ctrl+C exits back to filemanager
            env = os.environ.copy()
            env['NODE_OPTIONS'] = '--max-old-space-size=4096'
            
            process = subprocess.Popen([pi_path],
                cwd=str(self.current_dir),
                stderr=subprocess.PIPE,
                env=env,
                preexec_fn=lambda: signal.signal(signal.SIGINT, signal.SIG_DFL))
            process.wait()
            
            # Reset terminal state after pixel-index (it uses alternate screen, mouse, etc.)
            import sys
            sys.stdout.write('\x1b[?1049l')  # Leave alternate screen buffer
            sys.stdout.write('\x1b[?25h')    # Show cursor
            sys.stdout.write('\x1b[?1000l')  # Disable mouse tracking
            sys.stdout.write('\x1b[?1002l')  # Disable mouse button tracking
            sys.stdout.write('\x1b[?1003l')  # Disable all mouse tracking
            sys.stdout.write('\x1b[?1006l')  # Disable SGR mouse mode
            sys.stdout.flush()
            
            # Use os.system reset to fully clear terminal state
            os.system('stty sane 2>/dev/null')
            os.system('reset 2>/dev/null')
            
            # Check if pixel-index crashed
            if process.returncode != 0:
                stderr_output = process.stderr.read().decode('utf-8', errors='replace').strip()
                if stderr_output:
                    # Show last few lines of error
                    error_lines = stderr_output.split('\n')[-3:]
                    error_msg = '; '.join(error_lines)[:200]
                    self._restore_curses()
                    self.load_directory()
                    self.message = f"pixel-index error: {error_msg}"
                    self.message_color = curses.COLOR_RED
                    return
                else:
                    self._restore_curses()
                    self.load_directory()
                    self.message = f"pixel-index exited with code {process.returncode} (too many files?)"
                    self.message_color = curses.COLOR_RED
                    return
            
        except Exception as e:
            print(f"Error: {e}")
            print("Press Enter to continue...")
            try:
                input()
            except (KeyboardInterrupt, EOFError):
                pass
        
        # Restore curses
        self._restore_curses()
        self.load_directory()
        self.message = "Image viewer closed"
        self.message_color = curses.COLOR_GREEN

    def run(self):
        """Main loop"""
        while self.running:
            self.draw()
            
            key = self.stdscr.getch()
            
            # Clear message on any key
            if self.message:
                self.message = ""

            sidebar_handled = False
            if self.active_panel == 'sidebar' and self.show_sidebar:
                if key == curses.KEY_UP:
                    if self.sidebar_items:
                        self.sidebar_selected = max(0, self.sidebar_selected - 1)
                    sidebar_handled = True
                elif key == curses.KEY_DOWN:
                    if self.sidebar_items:
                        self.sidebar_selected = min(len(self.sidebar_items) - 1, self.sidebar_selected + 1)
                    sidebar_handled = True
                elif key in [ord('\n'), curses.KEY_ENTER, 10, 13]:
                    if self.sidebar_items:
                        item_type, item_data, _indent = self.sidebar_items[self.sidebar_selected]
                        if item_type == 'quick':
                            target = item_data['path']
                            target_resolved = target.resolve()
                            home = Path.home().resolve()
                            if target_resolved == home or home in target_resolved.parents:
                                path_cursor = home
                                self.tree_expanded[str(path_cursor)] = True
                                for part in target_resolved.relative_to(home).parts:
                                    path_cursor = path_cursor / part
                                    self.tree_expanded[str(path_cursor.resolve())] = True
                            self.change_directory(target)
                        elif item_type == 'tree':
                            path = item_data['path']
                            path_key = str(path.resolve())
                            if not self.tree_expanded.get(path_key, False):
                                self.tree_expanded[path_key] = True
                                self._tree_dirty = True
                            else:
                                home = Path.home().resolve()
                                target_resolved = path.resolve()
                                if target_resolved == home or home in target_resolved.parents:
                                    path_cursor = home
                                    self.tree_expanded[str(path_cursor)] = True
                                    for part in target_resolved.relative_to(home).parts:
                                        path_cursor = path_cursor / part
                                        self.tree_expanded[str(path_cursor.resolve())] = True
                                self.change_directory(path)
                    sidebar_handled = True
                elif key == curses.KEY_LEFT:
                    if self.sidebar_items:
                        item_type, item_data, _indent = self.sidebar_items[self.sidebar_selected]
                        if item_type == 'tree':
                            path_key = str(item_data['path'].resolve())
                            self.tree_expanded[path_key] = False
                            self._tree_dirty = True
                    sidebar_handled = True
                elif key == curses.KEY_RIGHT:
                    if self.sidebar_items:
                        item_type, item_data, _indent = self.sidebar_items[self.sidebar_selected]
                        if item_type == 'tree':
                            path_key = str(item_data['path'].resolve())
                            self.tree_expanded[path_key] = True
                            self._tree_dirty = True
                    sidebar_handled = True
                elif key == ord(']') or key == 27:
                    self.active_panel = 'files'
                    sidebar_handled = True

            if sidebar_handled:
                continue
            
            if key == curses.KEY_UP:
                self.selected_index = max(0, self.selected_index - 1)
            
            elif key == curses.KEY_DOWN:
                self.selected_index = min(len(self.entries) - 1, self.selected_index + 1)
            
            elif key in [ord('\n'), curses.KEY_ENTER, 10, 13]:
                self.handle_enter()
            
            elif key in [curses.KEY_BACKSPACE, 127, 8]:
                # Go up one directory
                if self.current_dir != self.current_dir.parent:
                    self.change_directory(self.current_dir.parent)
            
            elif key == ord('h'):
                # Go to home
                self.change_directory(Path.home())
            
            elif key == ord('r'):
                # Go to root
                self.change_directory(Path("/"))
            
            elif key == ord('?'):
                # Toggle help
                self.show_help = not self.show_help

            elif key == curses.KEY_RESIZE:
                try:
                    if self.kitty.has_graphics:
                        kitty_delete_images()
                except Exception:
                    pass
                self.stdscr.clear()
                self.preview_cache = {'path': None, 'content': None, 'image_id': 0}
                self._cached_layout = None  # Invalidate layout cache on resize

            elif key == ord('/'):
                # Floating search palette
                self.show_command_palette(mode='search')

            elif key == ord(':'):
                # Floating command palette
                self.show_command_palette(mode='command')
            
            elif key == ord('q'):
                # Quit
                self.running = False

            elif key == ord('\t'):
                # Toggle sidebar panel visibility
                self.show_sidebar = not self.show_sidebar
                if not self.show_sidebar and self.active_panel == 'sidebar':
                    self.active_panel = 'files'
                self._cached_layout = None

            elif key == ord('['):
                # Focus sidebar when visible
                if self.show_sidebar:
                    self.active_panel = 'sidebar'

            elif key == ord('P'):
                # Toggle preview panel visibility
                self.show_preview = not self.show_preview
                self._cached_layout = None
            
            elif key == ord('b'):
                # Bookmarks
                self.show_bookmarks_menu()
            
            elif key == ord('p'):
                # Fix permissions
                self.fix_permissions()
            
            elif key == ord('e'):
                # Extract archives
                self.extract_archives()
            
            elif key == ord('f'):
                # Find empty folders
                self.find_empty_folders()
            
            elif key == ord(' '):
                # Toggle mark on current file
                self.toggle_mark()
            
            elif key == ord('a'):
                # Mark all files in current directory
                self.mark_all_files()
            
            elif key == ord('u'):
                # Unmark all files
                self.unmark_all_files()
            
            elif key == ord('c'):
                # Copy to clipboard
                self.copy_to_clipboard()
            
            elif key == ord('x'):
                # Cut to clipboard
                self.cut_to_clipboard()
            
            elif key == ord('v'):
                # Paste from clipboard
                self.paste_from_clipboard()
            
            elif key == ord('d'):
                # Delete file(s)
                self.delete_files()
            
            elif key == ord('n'):
                # Create new file or folder
