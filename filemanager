    def draw_footer(self, layout):
        """Draw 3-row footer: separator, status, and help hints."""
        width = layout['width']
        footer_y = layout['footer_y']

        compact_line = "↑↓ nav  ⏎ open  ␣ mark  / search  : cmd  Tab side  P preview  ? help  q quit"
        if layout['footer_rows'] == 1:
            if self.use_true_color:
                tc_addstr(self.stdscr, footer_y, 0, ' ' * width, bg=THEME['bg_surface'])
                tc_addstr(self.stdscr, footer_y, 1, compact_line[:max(0, width - 2)], fg=THEME['text_secondary'], bg=THEME['bg_surface'])
            else:
                self.stdscr.addstr(footer_y, 0, ' ' * width, curses.color_pair(14))
                self.stdscr.addstr(footer_y, 1, compact_line[:max(0, width - 2)], curses.color_pair(14))
            return

        # Footer separator row with panel junctions
        sep_chars = ['─'] * width
        if layout['sidebar_width'] > 0:
            bx = layout['sidebar_x'] + layout['sidebar_width']
            if 0 <= bx < width:
                sep_chars[bx] = '┴'
        if layout['preview_width'] > 0:
            bx = layout['preview_x']
            if 0 <= bx < width:
                sep_chars[bx] = '┴'
        sep_line = ''.join(sep_chars)

        if self.use_true_color:
            tc_addstr(self.stdscr, footer_y, 0, sep_line, fg=THEME['border_subtle'])
        else:
            self.stdscr.addstr(footer_y, 0, sep_line, curses.color_pair(14))

        # Row footer_y+1: left status
        check_icon = ICONS['check'] or '*'
        clipboard_icon = ICONS['clipboard'] or '[]'
        marked = len(self.selected_files)
        clip_count = len(self.clipboard)
        clip_mode = self.clipboard_operation or '-'
        left_status = f" {check_icon} {marked}  {clipboard_icon} {clip_count}:{clip_mode} "

        # Center disk usage mini bar (cached per directory via _disk_info)
        center_status = ""
        disk_color = THEME['accent_green']
        try:
            if not hasattr(self, '_disk_cache_dir') or self._disk_cache_dir != str(self.current_dir):
                self._disk_cache_dir = str(self.current_dir)
                st = os.statvfs(str(self.current_dir))
                total = st.f_blocks * st.f_frsize
                avail = st.f_bavail * st.f_frsize
                self._disk_cache = (total, avail)
            else:
                total, avail = self._disk_cache
            used = max(0, total - avail)
            pct = (used / total * 100.0) if total else 0.0
            if pct >= 85:
                disk_color = THEME['accent_rose']
            elif pct >= 60:
                disk_color = THEME['accent_warm']

            filled = min(10, max(0, int(round(pct / 10.0))))
            bar = '█' * filled + '░' * (10 - filled)

            def fmt_bytes(v):
                for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
                    if v < 1024.0:
                        if unit == 'B':
                            return f"{int(v)}{unit}"
                        return f"{v:.1f}{unit}"
                    v /= 1024.0
                return f"{v:.1f}PB"

            center_status = f"💾 {fmt_bytes(used)} / {fmt_bytes(total)} {bar}"
        except Exception:
            center_status = "💾 n/a"

        # Right selected perms
        right_status = ""
        if self.entries and 0 <= self.selected_index < len(self.entries):
            sel = self.entries[self.selected_index]
            right_status = f" {sel.get('perms', '')} "

        row_y = footer_y + 1
        center_x = max(0, (width - len(center_status)) // 2)
        right_x = max(0, width - len(right_status) - 1)

        if self.use_true_color:
            tc_addstr(self.stdscr, row_y, 0, ' ' * width, bg=THEME['bg_surface'])
            tc_addstr(self.stdscr, row_y, 1, left_status[:max(0, center_x - 2)], fg=THEME['text_secondary'], bg=THEME['bg_surface'])
            tc_addstr(self.stdscr, row_y, center_x, center_status[:max(0, right_x - center_x - 1)], fg=disk_color, bg=THEME['bg_surface'], bold=True)
            if right_status:
                tc_addstr(self.stdscr, row_y, right_x, right_status[:width - right_x], fg=THEME['text_secondary'], bg=THEME['bg_surface'])
        else:
            self.stdscr.addstr(row_y, 0, ' ' * width, curses.color_pair(14))
            self.stdscr.addstr(row_y, 1, left_status[:max(0, center_x - 2)], curses.color_pair(14))
            self.stdscr.addstr(row_y, center_x, center_status[:max(0, right_x - center_x - 1)], curses.color_pair(11) | curses.A_BOLD)
            if right_status:
                self.stdscr.addstr(row_y, right_x, right_status[:width - right_x], curses.color_pair(14))

        # Row footer_y+2: help hints (keys dim, descriptions secondary)
        hints = [
            ('↑↓', 'nav'), ('⏎', 'open'), ('␣', 'mark'), ('/', 'search'),
            (':', 'cmd'), ('Tab', 'side'), ('P', 'preview'), ('?', 'help'), ('q', 'quit')
        ]

        if self.use_true_color:
            tc_addstr(self.stdscr, footer_y + 2, 0, ' ' * width, bg=THEME['bg_surface'])
            x = 1
            for key_txt, label_txt in hints:
                seg = f"{key_txt} {label_txt}  "
                if x + len(seg) >= width:
                    break
                tc_addstr(self.stdscr, footer_y + 2, x, key_txt, fg=THEME['text_dim'], bg=THEME['bg_surface'])
                tc_addstr(self.stdscr, footer_y + 2, x + len(key_txt) + 1, label_txt, fg=THEME['text_secondary'], bg=THEME['bg_surface'])
                x += len(seg)
        else:
            line = "↑↓ nav  ⏎ open  ␣ mark  / search  : cmd  Tab side  P preview  ? help  q quit"
            self.stdscr.addstr(footer_y + 2, 0, ' ' * width, curses.color_pair(14))
            self.stdscr.addstr(footer_y + 2, 1, line[:width - 2], curses.color_pair(14))

    def _get_ext_badge_colors(self, ext):
        """Get badge fg/bg colors for file extension."""
        ext = ext.upper().lstrip('.')
        badges = {
            'FLAC': (THEME['accent_green'], (42, 74, 42)),
            'MP3': (THEME['accent_orange'], (74, 58, 42)),
            'WAV': (THEME['accent_blue'], (42, 58, 92)),
            'MP4': (THEME['accent_rose'], (74, 42, 42)),
            'MKV': (THEME['accent_rose'], (74, 42, 42)),
            'AVI': (THEME['accent_rose'], (74, 42, 42)),
            'PY': (THEME['accent_blue'], (42, 58, 92)),
            'JS': (THEME['accent_warm'], (74, 74, 42)),
            'TS': (THEME['accent_blue'], (42, 58, 92)),
            'JSON': (THEME['accent_warm'], (58, 58, 42)),
            'ZIP': (THEME['accent_green'], (42, 58, 42)),
            'RAR': (THEME['accent_green'], (42, 58, 42)),
            'PNG': (THEME['accent_orange'], (74, 58, 42)),
            'JPG': (THEME['accent_orange'], (74, 58, 42)),
            'GIF': (THEME['accent_secondary'], (58, 42, 74)),
            'MD': (THEME['text_secondary'], (42, 42, 52)),
            'TXT': (THEME['text_secondary'], (42, 42, 52)),
            'PDF': (THEME['accent_rose'], (74, 42, 42)),
        }
        return badges.get(ext, (THEME['text_dim'], (42, 42, 52)))
    
    def draw_entries(self, layout):
        """Draw entries inside the file-list panel area."""
        x = layout['files_x']
        w = layout['files_width']
        y0 = layout['content_start_y']
        visible_count = max(0, layout['content_height'])
        y_end = y0 + visible_count

        if visible_count <= 0 or w <= 0:
            return

        # Adjust scroll offset for panel-local viewport
        if self.selected_index < self.scroll_offset:
            self.scroll_offset = self.selected_index
        elif self.selected_index >= self.scroll_offset + visible_count:
            self.scroll_offset = self.selected_index - visible_count + 1

        def blend(c1, c2, t):
            return (
                int(c1[0] + (c2[0] - c1[0]) * t),
                int(c1[1] + (c2[1] - c1[1]) * t),
                int(c1[2] + (c2[2] - c1[2]) * t),
            )

        def theme_file_color(entry):
            if entry['is_dir']:
                return THEME['accent_blue']
            ext = entry['path'].suffix.lower()
            if ext in {'.zip', '.tar', '.gz', '.tgz', '.bz2', '.tbz2', '.xz', '.txz', '.rar', '.7z'}:
                return THEME['accent_green']
            if ext in {'.mp3', '.flac', '.wav', '.m4a', '.aac', '.ogg', '.opus', '.wma'}:
                return THEME['accent_secondary']
            if ext in {'.mp4', '.mkv', '.avi', '.mov', '.wmv', '.flv', '.webm'}:
                return THEME['accent_rose']
            if ext in {'.jpg', '.jpeg', '.png', '.gif', '.bmp', '.svg', '.webp'}:
                return THEME['accent_warm']
            if ext in {'.py', '.js', '.jsx', '.ts', '.tsx', '.java', '.c', '.cpp', '.h',
                       '.cs', '.php', '.rb', '.go', '.rs', '.swift', '.sh', '.bash'}:
                return THEME['accent_blue']
            return THEME['text_primary']

        scrollbar_needed = len(self.entries) > visible_count
        content_w = w - (1 if scrollbar_needed else 0)

        # Background is already set by bkgd()+erase() for true color,
        # only paint explicitly for non-256-color mode
        if not self.use_true_color:
            for y in range(y0, y_end):
                try:
                    self.stdscr.addstr(y, x, ' ' * w, curses.color_pair(14))
                except curses.error:
                    pass

        # Draw each visible entry
        check_icon = ICONS['check'] or '✓'
        for i in range(visible_count):
            entry_index = i + self.scroll_offset
            if entry_index >= len(self.entries):
                break

            entry = self.entries[entry_index]
            y = y0 + i
            is_selected = entry_index == self.selected_index
            is_marked = entry['path'] in self.selected_files

            icon = self.get_file_icon(entry) or ' '
            size_str = '<DIR>' if entry['is_dir'] else self.get_size_string(entry['size']).strip()
            perms = entry.get('perms', '')
            marker = f" {check_icon} " if is_marked else "   "

            git_indicator = ' '
            git_color = THEME['text_dim']
            if entry['name'] != '..' and self._git_status:
                rel_path = None
                if self._git_root is not None:
                    try:
                        rel_path = entry['path'].resolve().relative_to(self._git_root.resolve()).as_posix()
                    except (RuntimeError, ValueError, OSError):
                        rel_path = None
                if rel_path is None:
                    rel_path = entry['name']

                git_state = self._git_status.get(rel_path)
                if git_state == 'modified':
                    git_indicator = '●'
                    git_color = THEME['accent_orange']
                elif git_state == 'added':
                    git_indicator = '+'
                    git_color = THEME['accent_green']
                elif git_state == 'untracked':
                    git_indicator = '?'
                    git_color = THEME['text_dim']
                elif git_state == 'deleted':
                    git_indicator = '-'
                    git_color = THEME['accent_rose']
                elif git_state == 'renamed':
                    git_indicator = '↻'
                    git_color = THEME['accent_blue']

            ext_badge = ''
            if self.use_true_color and w > 80 and not entry['is_dir']:
                ext = entry['path'].suffix.upper().lstrip('.')
                if ext:
                    ext_badge = f" {ext[:5]} "

            left = f"{marker}{git_indicator}{icon} "
            reserved = len(left) + 1 + 10 + 1 + 10 + (len(ext_badge) + 1 if ext_badge else 0)
            name_w = max(6, content_w - reserved)

            name = entry['name']
            if len(name) > name_w:
                name = name[:name_w - 1] + '…'

            base_text = f"{left}{name:<{name_w}} {perms:<10} {size_str:>10}"
            if ext_badge:
                base_text += f" {ext_badge}"
            row_text = base_text[:content_w].ljust(content_w)

            try:
                if self.use_true_color and is_selected:
                    # Chunked horizontal gradient selection (5 segments instead of per-char).
                    num_segs = 5
                    seg_len = max(1, content_w // num_segs)
                    # Left-edge marker
                    bg0 = blend(THEME['gradient_sel_1'], THEME['gradient_sel_2'], 0.0)
                    tc_addstr(self.stdscr, y, x, '▌', fg=THEME['accent_primary'], bg=bg0, bold=True)
                    pos = 1
                    for seg in range(num_segs):
                        seg_start = max(1, seg * seg_len) if seg > 0 else 1
                        seg_end = min(content_w, (seg + 1) * seg_len) if seg < num_segs - 1 else content_w
                        if seg_start >= seg_end:
                            continue
                        t = ((seg_start + seg_end) / 2) / max(1, content_w - 1)
                        bg = blend(THEME['gradient_sel_1'], THEME['gradient_sel_2'], t)
                        chunk = row_text[seg_start:seg_end]
                        tc_addstr(self.stdscr, y, x + seg_start, chunk, fg=THEME['text_primary'], bg=bg, bold=True)
                    if git_indicator.strip():
                        gi_x = x + len(marker)
                        gi_i = gi_x - x
                        t = (gi_i / max(1, content_w - 1))
                        gi_bg = blend(THEME['gradient_sel_1'], THEME['gradient_sel_2'], t)
                        tc_addstr(self.stdscr, y, gi_x, git_indicator, fg=git_color, bg=gi_bg, bold=True)
                elif self.use_true_color and is_marked:
                    tc_addstr(self.stdscr, y, x, row_text, fg=THEME['text_primary'], bg=THEME['mark_bg'])
                    tc_addstr(self.stdscr, y, x + 1, check_icon, fg=THEME['accent_warm'], bg=THEME['mark_bg'], bold=True)
                    if git_indicator.strip():
                        tc_addstr(self.stdscr, y, x + len(marker), git_indicator, fg=git_color, bg=THEME['mark_bg'], bold=True)
                elif self.use_true_color:
                    tc_addstr(self.stdscr, y, x, row_text, fg=THEME['text_primary'], bg=THEME['bg_base'])
                    gi_x = x + len(marker)
                    icon_x = gi_x + 1
                    if git_indicator.strip():
                        tc_addstr(self.stdscr, y, gi_x, git_indicator, fg=git_color, bg=THEME['bg_base'], bold=True)
                    tc_addstr(self.stdscr, y, icon_x, icon, fg=theme_file_color(entry), bg=THEME['bg_base'])
                    suffix_x = x + len(left) + name_w + 1
                    tc_addstr(self.stdscr, y, suffix_x, f"{perms:<10} {size_str:>10}"[:max(0, content_w - (suffix_x - x))], fg=THEME['text_secondary'], bg=THEME['bg_base'])

                    if ext_badge:
                        badge_x = suffix_x + len(f"{perms:<10} {size_str:>10}") + 1
                        if badge_x + len(ext_badge) <= x + content_w:
                            badge_fg, badge_bg = self._get_ext_badge_colors(ext_badge.strip())
                            tc_addstr(self.stdscr, y, badge_x, ext_badge, fg=badge_fg, bg=badge_bg, bold=True)
                else:
                    if is_selected:
                        self.stdscr.addstr(y, x, row_text, curses.color_pair(7) | curses.A_BOLD)
                    elif is_marked:
                        self.stdscr.addstr(y, x, row_text, curses.color_pair(12) | curses.A_BOLD)
                    else:
                        self.stdscr.addstr(y, x, row_text, self.get_file_color(entry))
                        icon_x = x + len(marker) + 1
                        self.stdscr.addstr(y, icon_x, icon, self.get_file_color(entry))
                        suffix_x = x + len(left) + name_w + 1
                        self.stdscr.addstr(y, suffix_x, f"{perms:<10} {size_str:>10}"[:max(0, content_w - (suffix_x - x))], curses.color_pair(14))
            except curses.error:
                pass

        # Scrollbar
        if scrollbar_needed and w > 1:
            track_x = x + w - 1
            thumb_size = max(1, int(visible_count * visible_count / max(1, len(self.entries))))
            thumb_pos = int((self.scroll_offset / max(1, len(self.entries) - visible_count)) * max(0, visible_count - thumb_size))

            for i in range(visible_count):
                y = y0 + i
                is_thumb = thumb_pos <= i < thumb_pos + thumb_size
                ch = '█' if is_thumb else '│'
                try:
                    if self.use_true_color:
                        tc_addstr(
                            self.stdscr,
                            y,
                            track_x,
                            ch,
                            fg=THEME['accent_primary'] if is_thumb else THEME['text_dim'],
                            bg=THEME['bg_base'],
                            bold=is_thumb,
                        )
                    else:
                        self.stdscr.addstr(y, track_x, ch, (curses.color_pair(50) | curses.A_BOLD) if is_thumb else curses.color_pair(51))
                except curses.error:
                    pass

    def draw_panel_borders(self, layout):
        """Draw vertical separators between panels, highlighting active panel boundaries."""
        height = layout['height']

        def border_color_for(separator_kind):
            if separator_kind == 'left':
                active = self.active_panel in {'sidebar', 'files'}
            else:
                active = self.active_panel in {'files', 'preview'}
            if self.use_true_color:
                return THEME['border_accent'] if active else THEME['border_subtle']
            return curses.color_pair(19) if active else curses.color_pair(14)

        if layout['sidebar_width'] > 0:
            x = layout['sidebar_x'] + layout['sidebar_width']
            if self.use_true_color:
                attr = _tc_attr(fg=border_color_for('left'))
                for y in range(0, height):
                    try:
                        self.stdscr.addstr(y, x, '│', attr)
                    except curses.error:
                        pass
            else:
                attr = border_color_for('left')
                for y in range(0, height):
                    try:
                        self.stdscr.addstr(y, x, '│', attr)
                    except curses.error:
                        pass

        if layout['preview_width'] > 0:
            x = layout['preview_x']
            if self.use_true_color:
                attr = _tc_attr(fg=border_color_for('right'))
                for y in range(0, height):
                    try:
                        self.stdscr.addstr(y, x, '│', attr)
                    except curses.error:
                        pass
            else:
                attr = border_color_for('right')
                for y in range(0, height):
                    try:
                        self.stdscr.addstr(y, x, '│', attr)
                    except curses.error:
                        pass

    def draw_sidebar(self, layout):
        """Draw sidebar panel with quick access and expandable directory tree."""
        if layout['sidebar_width'] == 0:
            self.sidebar_items = []
            self.sidebar_selected = 0
            return

        x = layout['sidebar_x']
        w = layout['sidebar_width']
        y_start = layout['content_start_y']
        y_end = layout['footer_y']
        panel_h = max(0, y_end - y_start)
        inner_w = max(0, w - 2)

        # Paint sidebar background
        if self.use_true_color:
            bg_attr = _tc_attr(bg=THEME['bg_surface'])
            blank = ' ' * w
            for y in range(y_start, y_end):
                try:
                    self.stdscr.addstr(y, x, blank, bg_attr)
                except curses.error:
                    pass
        else:
            blank = ' ' * w
            attr = curses.color_pair(14)
            for y in range(y_start, y_end):
                try:
                    self.stdscr.addstr(y, x, blank, attr)
                except curses.error:
                    pass

        if panel_h <= 0 or inner_w <= 0:
            self.sidebar_items = []
            self.sidebar_selected = 0
            return

        def draw_line(y, text, fg=None, bg=None, bold=False):
            if y < y_start or y >= y_end:
                return
            clipped = text[:inner_w]
            padded = clipped.ljust(inner_w)
            try:
                if self.use_true_color:
                    tc_addstr(self.stdscr, y, x + 1, padded, fg=fg, bg=bg or THEME['bg_surface'], bold=bold)
                else:
                    attr = curses.color_pair(14)
                    if bold:
                        attr |= curses.A_BOLD
                    self.stdscr.addstr(y, x + 1, padded, attr)
            except curses.error:
                pass

        def add_quick_item(label, path, icon=''):
            quick_items.append({'label': label, 'path': path, 'icon': icon})

        # Build tree lazily (only when dirty)
        self._build_tree()

        home = Path.home().resolve()
        quick_items = []
        add_quick_item('Home', home, '⌂')
        add_quick_item('Root', Path('/'), '/')

        for name, icon in [
            ('Downloads', '↓'),
            ('Documents', '⌘'),
            ('Music', '♪'),
            ('Pictures', '◉'),
            ('Videos', '▶'),
        ]:
            p = home / name
            if p.exists() and p.is_dir():
                add_quick_item(name, p, icon)

        for bookmark_name, bookmark_path in self.config.get_bookmarks().items():
            try:
                p = Path(bookmark_path).expanduser().resolve()
                if p.exists() and p.is_dir():
                    add_quick_item(bookmark_name, p, '★')
            except (OSError, RuntimeError, ValueError):
                continue

        # Use cached tree data (rebuilt on directory change / expand/collapse)
        tree_items = list(getattr(self, '_tree_items', []))

        quick_rows_needed = len(quick_items) + 3  # header + separator + items + blank line
        tree_rows = max(0, panel_h - quick_rows_needed)

        y = y_start
        draw_line(y, '★ QUICK ACCESS', fg=THEME['accent_warm'], bold=True)
        y += 1
        draw_line(y, '─' * inner_w, fg=THEME['text_dim'])
        y += 1

        self.sidebar_items = []

        current_dir_resolved = self.current_dir.resolve()

        for item in quick_items:
            label = f" {item['icon']} {item['label']}"
            is_current = False
            try:
                is_current = item['path'].resolve() == current_dir_resolved
            except (OSError, RuntimeError):
                is_current = False

            idx = len(self.sidebar_items)
            self.sidebar_items.append(('quick', item, 0))
            is_selected = (self.active_panel == 'sidebar' and self.sidebar_selected == idx)

            fg = THEME['accent_primary'] if is_current else THEME['text_secondary']
            bg = THEME['bg_selection_accent'] if is_selected else THEME['bg_surface']
            draw_line(y, label, fg=fg, bg=bg, bold=is_current or is_selected)
            y += 1
            if y >= y_end:
                break

        if y < y_end:
            draw_line(y, '', fg=THEME['text_dim'])
            y += 1

        if tree_rows > 0 and y < y_end:
            draw_line(y, ' TREE', fg=THEME['accent_warm'], bold=True)
            y += 1
        if tree_rows > 1 and y < y_end:
            draw_line(y, '─' * inner_w, fg=THEME['text_dim'])
            y += 1

        # Reserve 2 lines for tree header/separator
        tree_visible_rows = max(0, tree_rows - 2)

        # Determine selection index inside tree list for scrolling
        selected_tree_idx = 0
        if self.active_panel == 'sidebar':
            for idx, item in enumerate(self.sidebar_items):
                if idx == self.sidebar_selected and item[0] == 'tree':
                    selected_tree_idx = sum(1 for t in self.sidebar_items[:idx] if t[0] == 'tree')
                    break

        tree_scroll = self.sidebar_scroll
        if tree_visible_rows > 0:
            if selected_tree_idx < tree_scroll:
                tree_scroll = selected_tree_idx
            elif selected_tree_idx >= tree_scroll + tree_visible_rows:
                tree_scroll = selected_tree_idx - tree_visible_rows + 1
            max_scroll = max(0, len(tree_items) - tree_visible_rows)
            tree_scroll = max(0, min(tree_scroll, max_scroll))
        else:
            tree_scroll = 0
        self.sidebar_scroll = tree_scroll

        visible_tree = tree_items[tree_scroll:tree_scroll + tree_visible_rows]

        for tree_item in visible_tree:
            idx = len(self.sidebar_items)
            self.sidebar_items.append(('tree', tree_item, tree_item['depth']))

            marker = '▾' if tree_item['is_expanded'] else '▸'
            line_text = f"{tree_item['tree_prefix']}{marker} {tree_item['name']}"

            is_current = False
            try:
                is_current = tree_item['path'].resolve() == current_dir_resolved
            except (OSError, RuntimeError):
                is_current = False

            is_selected = (self.active_panel == 'sidebar' and self.sidebar_selected == idx)
            fg = THEME['accent_blue']
            bg = THEME['bg_selection_accent'] if (is_current or is_selected) else THEME['bg_surface']
            draw_line(y, line_text, fg=fg, bg=bg, bold=(is_current or is_selected))
            y += 1
            if y >= y_end:
                break

        # Clamp selection to available sidebar items
        if not self.sidebar_items:
            self.sidebar_selected = 0
        else:
            self.sidebar_selected = max(0, min(self.sidebar_selected, len(self.sidebar_items) - 1))

    def _ffprobe_info(self, path):
        """Get media info via ffprobe. Returns dict or None."""
        try:
            result = subprocess.run(
                ['ffprobe', '-v', 'quiet', '-print_format', 'json', '-show_format', '-show_streams', str(path)],
                capture_output=True,
                text=True,
                timeout=1,
            )
            if result.returncode == 0 and result.stdout.strip():
                return json.loads(result.stdout)
        except Exception:
            pass
        return None

    def _get_image_dimensions(self, path):
        """Get image dimensions using identify (ImageMagick)."""
        try:
            result = subprocess.run(
                ['identify', '-format', '%wx%h', str(path)],
                capture_output=True,
                text=True,
                timeout=1,
            )
            if result.returncode == 0:
                parts = result.stdout.strip().split('x')
                if len(parts) == 2:
                    return int(parts[0]), int(parts[1])
        except Exception:
            pass
        return None, None

    def draw_preview(self, layout):
        """Draw contextual preview for the currently selected entry."""
        if layout['preview_width'] == 0:
            return

        x = layout['preview_x']
        w = layout['preview_width']
        y_start = layout['content_start_y']
        y_end = layout['footer_y']
        inner_w = max(0, w - 2)

        if y_end <= y_start:
            return

        selected_entry = None
        if self.entries and 0 <= self.selected_index < len(self.entries):
            selected_entry = self.entries[self.selected_index]

        selected_path = selected_entry['path'] if selected_entry else None
        same_path = self.preview_cache.get('path') == selected_path

        if not same_path:
            kitty_delete_images()
            self.preview_cache['image_id'] = 0
            self.preview_cache['_kitty_sent'] = False

        # Fill panel background
        if self.use_true_color:
            bg_attr = _tc_attr(bg=THEME['bg_surface'])
            blank = ' ' * w
            for y in range(y_start, y_end):
                try:
                    self.stdscr.addstr(y, x, blank, bg_attr)
                except curses.error:
                    pass
        else:
            blank = ' ' * w
            attr = curses.color_pair(14)
            for y in range(y_start, y_end):
                try:
                    self.stdscr.addstr(y, x, blank, attr)
                except curses.error:
                    pass

        def draw_line(y, text, fg=None, bg=None, bold=False, dim=False):
            if y < y_start or y >= y_end or inner_w <= 0:
                return
            clipped = text[:inner_w]
            padded = clipped.ljust(inner_w)
            try:
                if self.use_true_color:
                    tc_addstr(
                        self.stdscr,
                        y,
                        x + 1,
                        padded,
                        fg=fg,
                        bg=bg or THEME['bg_surface'],
                        bold=bold,
                        dim=dim,
                    )
                else:
                    attr = curses.color_pair(14)
                    if bold:
                        attr |= curses.A_BOLD
                    if dim:
                        attr |= curses.A_DIM
                    self.stdscr.addstr(y, x + 1, padded, attr)
            except curses.error:
                pass

        def format_duration(seconds):
            try:
                seconds = float(seconds)
            except (ValueError, TypeError):
                return '00:00'
            if seconds < 0:
                return '00:00'
            hours = int(seconds // 3600)
            minutes = int((seconds % 3600) // 60)
            secs = int(seconds % 60)
            if hours > 0:
                return f"{hours:02d}:{minutes:02d}:{secs:02d}"
            return f"{minutes:02d}:{secs:02d}"

        def format_bitrate(bitrate):
            try:
                bitrate = int(float(str(bitrate)))
            except (ValueError, TypeError):
                return 'N/A'
            if bitrate <= 0:
                return 'N/A'
            if bitrate >= 1_000_000:
                return f"{bitrate / 1_000_000:.1f} Mbps"
            if bitrate >= 1_000:
                return f"{bitrate / 1_000:.0f} kbps"
            return f"{bitrate} bps"

        def parse_fps(value):
            try:
                if isinstance(value, str) and '/' in value:
                    num, den = value.split('/', 1)
                    den_f = float(den)
                    return float(num) / den_f if den_f else 0.0
                return float(value)
            except (ValueError, TypeError):
                return 0.0

        def audio_quality_score(info):
            sample_rate = int(info.get('sample_rate') or 0)
            bit_rate = int(info.get('bit_rate') or 0)
            codec = str(info.get('codec', '')).lower()

            score = 0
            if sample_rate >= 192000:
                score += 30
            elif sample_rate >= 96000:
                score += 28
            elif sample_rate >= 48000:
                score += 25
            elif sample_rate >= 44100:
                score += 20
            else:
                score += 10

            if bit_rate >= 1411000:
                score += 35
            elif bit_rate >= 320000:
                score += 30
            elif bit_rate >= 256000:
                score += 25
            elif bit_rate >= 192000:
                score += 20
            elif bit_rate >= 128000:
                score += 15
            else:
                score += 5

            if codec in {'flac', 'alac', 'ape', 'wav'}:
                score += 15
            elif codec in {'aac', 'opus', 'vorbis'}:
                score += 10
            elif codec == 'mp3':
                score += 8
            else:
                score += 5

            return max(0, min(100, score))

        # Header + separator
        header_label = 'PREVIEW'
        if selected_entry:
            header_label = selected_entry['name']
        header_label = header_label[:max(0, inner_w)]
        label_x = x + 1 + max(0, (inner_w - len(header_label)) // 2)
        try:
            if self.use_true_color:
                tc_addstr(self.stdscr, y_start, x, ' ' * w, bg=THEME['bg_surface'])
                tc_addstr(self.stdscr, y_start, label_x, header_label, fg=THEME['text_dim'], bg=THEME['bg_surface'])
            else:
                self.stdscr.addstr(y_start, x, ' ' * w, curses.color_pair(14))
                self.stdscr.addstr(y_start, label_x, header_label, curses.color_pair(14))
        except curses.error:
            pass

        if y_start + 1 < y_end:
            sep = '─' * w
            try:
                if self.use_true_color:
                    tc_addstr(self.stdscr, y_start + 1, x, sep, fg=THEME['border_subtle'], bg=THEME['bg_surface'])
                else:
                    self.stdscr.addstr(y_start + 1, x, sep, curses.color_pair(14))
            except curses.error:
                pass

        content_top = y_start + 2
        content_height = max(0, y_end - content_top)
        if content_height <= 0:
            return

        if not selected_entry:
            draw_line(content_top, 'No selection', fg=THEME['text_dim'])
            self.preview_cache['path'] = None
            self.preview_cache['content'] = None
            return

        preview_data = self.preview_cache.get('content') if same_path else None

        if preview_data is None:
            path = selected_entry['path']
            preview_data = {
                'type': 'other',
                'path': path,
            }

            if selected_entry['is_dir']:
                file_count = 0
                total_size = 0
                type_sizes = defaultdict(int)
                type_counts = defaultdict(int)
                capped = False
                try:
                    for root, dirs, files in os.walk(path):
                        # Limit directory depth to avoid deep scans
                        depth = root.count(os.sep) - str(path).count(os.sep)
                        if depth >= 2:
                            dirs.clear()
                            continue
                        for file_name in files:
                            full_path = Path(root) / file_name
                            try:
                                size = full_path.stat().st_size
                            except Exception:
                                size = 0
                            category = self.get_file_type_category(full_path)
                            file_count += 1
                            total_size += size
                            type_sizes[category] += size
                            type_counts[category] += 1
                            if file_count >= 100:
                                capped = True
                                break
                        if capped:
                            break
                except Exception:
                    pass

                if capped:
                    analysis = {
                        'total_files': file_count,
                        'total_size': total_size,
                        'file_types': dict(type_counts),
                        'file_type_sizes': dict(type_sizes),
                        'partial': True,
                    }
                else:
                    analysis = self.analyze_directory_contents(path)
                    analysis['partial'] = False

                preview_data = {
                    'type': 'directory',
                    'path': path,
                    'analysis': analysis,
                }

            elif self.is_text_file(path):
                raw = b''
                encoding = 'utf-8'
                truncated = False
                error_text = None
                try:
                    with open(path, 'rb') as f:
                        raw = f.read(8192)
                        truncated = bool(f.read(1))
                except Exception as e:
                    error_text = str(e)

                text_data = ''
                if error_text is None:
                    try:
                        text_data = raw.decode('utf-8')
                        encoding = 'utf-8'
                    except UnicodeDecodeError:
                        text_data = raw.decode('utf-8', errors='replace')
                        encoding = 'utf-8 (replace)'

                preview_data = {
                    'type': 'text',
                    'path': path,
                    'encoding': encoding,
                    'text': text_data,
                    'error': error_text,
                    'truncated': truncated,
                }

            elif self.is_image_file(path):
                dims = self._get_image_dimensions(path)
                mime, _ = mimetypes.guess_type(str(path))

                ascii_art = None
                if not self.kitty.has_graphics:
                    chafa_path = shutil.which('chafa')
                    if chafa_path:
                        cols = max(10, inner_w)
                        rows = max(4, content_height - 6)
                        try:
                            chafa = subprocess.run(
                                ['chafa', '--size', f'{cols}x{rows}', str(path)],
                                capture_output=True,
                                text=True,
                                timeout=1,
                            )
                            if chafa.returncode == 0 and chafa.stdout.strip():
                                ascii_art = chafa.stdout.splitlines()
                        except Exception:
                            pass

                preview_data = {
                    'type': 'image',
                    'path': path,
                    'dims': dims,
                    'mime': mime,
                    'ascii_art': ascii_art,
                }

            elif self.is_audio_file(path):
                media = self._ffprobe_info(path)
                stream = None
                format_info = {}
                if media:
                    format_info = media.get('format', {})
                    for s in media.get('streams', []):
                        if s.get('codec_type') == 'audio':
                            stream = s
                            break

                bit_rate = 0
                sample_rate = 0
                channels = 0
                duration = 0.0
                codec = 'N/A'
                if stream:
                    try:
                        bit_rate = int(float(stream.get('bit_rate') or format_info.get('bit_rate') or 0))
                    except (ValueError, TypeError):
                        bit_rate = 0
                    try:
                        sample_rate = int(float(stream.get('sample_rate') or 0))
                    except (ValueError, TypeError):
                        sample_rate = 0
                    try:
                        channels = int(float(stream.get('channels') or 0))
                    except (ValueError, TypeError):
                        channels = 0
                    try:
                        duration = float(format_info.get('duration') or stream.get('duration') or 0)
                    except (ValueError, TypeError):
                        duration = 0.0
                    codec = stream.get('codec_name', 'N/A')

                preview_data = {
                    'type': 'audio',
                    'path': path,
                    'ext': path.suffix.upper().lstrip('.') or 'AUDIO',
                    'bit_rate': bit_rate,
                    'sample_rate': sample_rate,
                    'duration': duration,
                    'channels': channels,
                    'codec': codec,
                    'ffprobe_ok': media is not None,
                }

            elif self.is_video_file(path):
                media = self._ffprobe_info(path)
                stream = None
                format_info = {}
                if media:
                    format_info = media.get('format', {})
                    for s in media.get('streams', []):
                        if s.get('codec_type') == 'video' and s.get('disposition', {}).get('attached_pic', 0) != 1:
                            stream = s
                            break

                width_px = 0
                height_px = 0
                codec = 'N/A'
                bit_rate = 0
                fps = 0.0
                duration = 0.0
                if stream:
                    width_px = int(stream.get('width') or 0)
                    height_px = int(stream.get('height') or 0)
                    codec = stream.get('codec_name', 'N/A')
                    try:
                        bit_rate = int(float(stream.get('bit_rate') or format_info.get('bit_rate') or 0))
                    except (ValueError, TypeError):
                        bit_rate = 0
                    fps = parse_fps(stream.get('r_frame_rate', '0/1'))
                    if fps == 0.0:
                        fps = parse_fps(stream.get('avg_frame_rate', '0/1'))
                    try:
                        duration = float(format_info.get('duration') or stream.get('duration') or 0)
                    except (ValueError, TypeError):
                        duration = 0.0

                preview_data = {
                    'type': 'video',
                    'path': path,
                    'width': width_px,
                    'height': height_px,
                    'codec': codec,
                    'bit_rate': bit_rate,
                    'fps': fps,
                    'duration': duration,
                    'ffprobe_ok': media is not None,
                }

            else:
                mime, _ = mimetypes.guess_type(str(path))
                preview_data = {
                    'type': 'other',
                    'path': path,
                    'mime': mime or 'application/octet-stream',
                }

            self.preview_cache['path'] = selected_path
            self.preview_cache['content'] = preview_data

        path = preview_data.get('path', selected_entry['path'])
        info_y = content_top

        # Text preview
        if preview_data.get('type') == 'text':
            error_text = preview_data.get('error')
            if error_text:
                draw_line(info_y, 'Text preview unavailable', fg=THEME['text_dim'])
                draw_line(info_y + 1, error_text, fg=THEME['accent_rose'])
                return

            text = preview_data.get('text', '')
            lines = text.splitlines()
            total_lines = len(lines)
            encoding = preview_data.get('encoding', 'utf-8')

            draw_line(info_y, f"{path.name}  [{encoding}]", fg=THEME['text_primary'], bold=True)
            draw_line(info_y + 1, f"{total_lines} lines", fg=THEME['text_dim'])

            available_lines = max(0, content_height - 4)
            start_y = info_y + 2
            shown = min(len(lines), available_lines)

            for idx in range(shown):
                row = start_y + idx
                number = f"{idx + 1:>4} "
                body = lines[idx]
                if self.use_true_color:
                    draw_line(row, f"{number}{body}", fg=THEME['text_secondary'])
                    try:
                        tc_addstr(self.stdscr, row, x + 1, number[:inner_w], fg=THEME['text_dim'], bg=THEME['bg_surface'])
                    except curses.error:
                        pass
                else:
                    draw_line(row, f"{number}{body}", fg=THEME['text_secondary'])

            remaining = total_lines - shown
            if preview_data.get('truncated'):
                remaining = max(remaining, 1)
            if remaining > 0 and start_y + shown < y_end:
                draw_line(start_y + shown, f"… {remaining} more lines", fg=THEME['text_dim'])
            return

        # Directory preview
        if preview_data.get('type') == 'directory':
            analysis = preview_data.get('analysis', {})
            draw_line(info_y, f"{path.name}/", fg=THEME['accent_blue'], bold=True)
            draw_line(info_y + 1, f"Files: {analysis.get('total_files', 0)}", fg=THEME['text_secondary'])
            draw_line(info_y + 2, f"Size: {self.get_size_string(analysis.get('total_size', 0)).strip()}", fg=THEME['text_secondary'])
            if analysis.get('partial'):
                draw_line(info_y + 3, 'Partial scan (first 1000 files)', fg=THEME['text_dim'])

            type_sizes = analysis.get('file_type_sizes', {})
            total_size = sum(type_sizes.values())
            bar_y = info_y + 5
            if total_size > 0 and bar_y < y_end:
                chars = ['▏', '▎', '▍', '▌', '▋', '▊', '▉', '█']
                units = max(1, inner_w * 8)
                bar_units = 0
                bar = []
                sorted_types = sorted(type_sizes.items(), key=lambda kv: kv[1], reverse=True)
                for _, size in sorted_types:
                    width_units = max(1, int((size / total_size) * units))
                    bar_units += width_units
                    full = width_units // 8
                    rem = width_units % 8
                    bar.append('█' * full)
                    if rem > 0:
                        bar.append(chars[rem - 1])
                chart = ''.join(bar)
                if len(chart) < inner_w:
                    chart += ' ' * (inner_w - len(chart))
                draw_line(bar_y, chart[:inner_w], fg=THEME['accent_primary'])

            row = bar_y + 1
            for file_type, size in sorted(type_sizes.items(), key=lambda kv: kv[1], reverse=True):
                if row >= y_end:
                    break
                count = analysis.get('file_types', {}).get(file_type, 0)
                pct = (size / total_size * 100.0) if total_size > 0 else 0.0
                line = f"{file_type:<10} {count:>4}  {self.get_size_string(size).strip():>9}  {pct:>5.1f}%"
                draw_line(row, line, fg=THEME['text_secondary'])
                row += 1
            return

        # Common file info
        size_str = self.get_size_string(selected_entry.get('size', 0)).strip()

        # Image preview
        if preview_data.get('type') == 'image':
            dims = preview_data.get('dims', (None, None))
            if self.kitty.has_graphics:
                image_cols = max(8, w - 2)
                image_rows = max(4, content_height - 6)
                image_x = x + 1
                image_y = content_top
                if self.preview_cache.get('image_id', 0) == 0:
                    self.preview_cache['image_id'] = int(time.time() * 1000) % 100000
                # Only send image to Kitty if not already sent for this path
                if not self.preview_cache.get('_kitty_sent'):
                    kitty_send_image(str(path), image_x, image_y, image_cols, image_rows, image_id=self.preview_cache['image_id'])
                    self.preview_cache['_kitty_sent'] = True
                info_y = image_y + image_rows + 1
            else:
                ascii_art = preview_data.get('ascii_art')
                if ascii_art:
                    row = info_y
                    for line in ascii_art:
                        if row >= y_end - 4:
                            break
                        draw_line(row, line, fg=THEME['text_secondary'])
                        row += 1
                    info_y = min(y_end - 3, row + 1)

            draw_line(info_y, path.name, fg=THEME['text_primary'], bold=True)
            dim_text = 'Unknown dimensions'
            if dims and dims[0] and dims[1]:
                dim_text = f"{dims[0]}x{dims[1]}"
            draw_line(info_y + 1, f"{dim_text}  {size_str}", fg=THEME['text_secondary'])
            mime = preview_data.get('mime')
            if mime:
                draw_line(info_y + 2, mime, fg=THEME['text_dim'])
            return

        # Audio preview
        if preview_data.get('type') == 'audio':
            if self.kitty.has_graphics and shutil.which('ffmpeg') and not self.preview_cache.get('_kitty_sent'):
                art_tmp = None
                fd, art_tmp = tempfile.mkstemp(suffix='.jpg')
                os.close(fd)
                try:
                    subprocess.run(
                        ['ffmpeg', '-i', str(path), '-an', '-vcodec', 'copy', art_tmp, '-y'],
                        capture_output=True,
                        timeout=5,
                    )
                    if os.path.exists(art_tmp) and os.path.getsize(art_tmp) > 0:
                        image_cols = max(8, w - 2)
                        image_rows = max(4, content_height - 6)
                        image_x = x + 1
                        image_y = content_top
                        if self.preview_cache.get('image_id', 0) == 0:
                            self.preview_cache['image_id'] = int(time.time() * 1000) % 100000
                        kitty_send_image(art_tmp, image_x, image_y, image_cols, image_rows, image_id=self.preview_cache['image_id'])
                        self.preview_cache['_kitty_sent'] = True
                        info_y = image_y + image_rows + 1
                except Exception:
                    pass
                finally:
                    try:
                        if art_tmp and os.path.exists(art_tmp):
                            os.unlink(art_tmp)
                    except Exception:
                        pass

            ext_badge = preview_data.get('ext', 'AUDIO')
            draw_line(info_y, f"[{ext_badge}] {path.name}", fg=THEME['accent_secondary'], bold=True)
            if not preview_data.get('ffprobe_ok'):
                draw_line(info_y + 1, 'ffprobe unavailable', fg=THEME['text_dim'])
                draw_line(info_y + 2, f"Size: {size_str}", fg=THEME['text_secondary'])
                return

            bit_rate = preview_data.get('bit_rate', 0)
            sample_rate = preview_data.get('sample_rate', 0)
            duration = preview_data.get('duration', 0.0)
            channels = preview_data.get('channels', 0)
            codec = preview_data.get('codec', 'N/A')
            score = audio_quality_score({'bit_rate': bit_rate, 'sample_rate': sample_rate, 'codec': codec})
            bar_w = max(8, min(inner_w - 8, 20))
            fill = int((score / 100.0) * bar_w)
            qbar = ('━' * fill) + ('─' * max(0, bar_w - fill))

            draw_line(info_y + 1, f"Codec: {codec}", fg=THEME['text_secondary'])
            draw_line(info_y + 2, f"Bitrate: {format_bitrate(bit_rate)}", fg=THEME['text_secondary'])
            draw_line(info_y + 3, f"Sample: {sample_rate:,} Hz" if sample_rate else 'Sample: N/A', fg=THEME['text_secondary'])
            draw_line(info_y + 4, f"Duration: {format_duration(duration)}", fg=THEME['text_secondary'])
            draw_line(info_y + 5, f"Channels: {channels or 'N/A'}", fg=THEME['text_secondary'])
            draw_line(info_y + 6, f"Quality {score:>3}% {qbar}", fg=THEME['accent_primary'])
            draw_line(info_y + 7, f"Size: {size_str}", fg=THEME['text_dim'])
            return

        # Video preview
        if preview_data.get('type') == 'video':
            if self.kitty.has_graphics and shutil.which('ffmpeg') and not self.preview_cache.get('_kitty_sent'):
                thumb_tmp = None
                fd, thumb_tmp = tempfile.mkstemp(suffix='.jpg')
                os.close(fd)
                try:
                    subprocess.run(
                        ['ffmpeg', '-ss', '5', '-i', str(path), '-vf', 'thumbnail', '-frames:v', '1', thumb_tmp, '-y'],
                        capture_output=True,
                        timeout=10,
                    )
                    if os.path.exists(thumb_tmp) and os.path.getsize(thumb_tmp) > 0:
                        image_cols = max(8, w - 2)
                        image_rows = max(4, content_height - 6)
                        image_x = x + 1
                        image_y = content_top
                        if self.preview_cache.get('image_id', 0) == 0:
                            self.preview_cache['image_id'] = int(time.time() * 1000) % 100000
                        kitty_send_image(thumb_tmp, image_x, image_y, image_cols, image_rows, image_id=self.preview_cache['image_id'])
                        self.preview_cache['_kitty_sent'] = True
                        info_y = image_y + image_rows + 1
                except Exception:
                    pass
                finally:
                    try:
                        if thumb_tmp and os.path.exists(thumb_tmp):
                            os.unlink(thumb_tmp)
                    except Exception:
                        pass

            draw_line(info_y, path.name, fg=THEME['accent_rose'], bold=True)
            if not preview_data.get('ffprobe_ok'):
                draw_line(info_y + 1, 'ffprobe unavailable', fg=THEME['text_dim'])
                draw_line(info_y + 2, f"Size: {size_str}", fg=THEME['text_secondary'])
                return

            w_px = preview_data.get('width', 0)
            h_px = preview_data.get('height', 0)
            codec = preview_data.get('codec', 'N/A')
            bit_rate = preview_data.get('bit_rate', 0)
            fps = preview_data.get('fps', 0.0)
            duration = preview_data.get('duration', 0.0)

            draw_line(info_y + 1, f"Resolution: {w_px}x{h_px}" if w_px and h_px else 'Resolution: N/A', fg=THEME['text_secondary'])
            draw_line(info_y + 2, f"Codec: {codec}", fg=THEME['text_secondary'])
            draw_line(info_y + 3, f"Bitrate: {format_bitrate(bit_rate)}", fg=THEME['text_secondary'])
            draw_line(info_y + 4, f"FPS: {fps:.2f}" if fps else 'FPS: N/A', fg=THEME['text_secondary'])
            draw_line(info_y + 5, f"Duration: {format_duration(duration)}", fg=THEME['text_secondary'])
            draw_line(info_y + 6, f"Size: {size_str}", fg=THEME['text_dim'])
            return

        # Generic file info card
        mime = preview_data.get('mime') or 'application/octet-stream'
        draw_line(info_y, path.name, fg=THEME['text_primary'], bold=True)
        draw_line(info_y + 1, f"Size: {size_str}", fg=THEME['text_secondary'])
        draw_line(info_y + 2, f"Perms: {selected_entry.get('perms', self.get_permissions_string(path))}", fg=THEME['text_secondary'])
        draw_line(info_y + 3, f"MIME: {mime}", fg=THEME['text_dim'])
    
    def draw(self):
        """Draw the entire interface."""
        try:
            if self.use_true_color:
                self.stdscr.bkgd(' ', _tc_attr(bg=THEME['bg_base']))
            self.stdscr.erase()
            layout = self._calc_layout()
            self.draw_panel_borders(layout)
            self.draw_header(layout)
            if layout['sidebar_width'] > 0:
                self.draw_sidebar(layout)
            self.draw_entries(layout)
            if layout['preview_width'] > 0:
                self.draw_preview(layout)
            self.draw_footer(layout)
            self.stdscr.refresh()
        except curses.error:
            pass
        except Exception:
            try:
                self.stdscr.refresh()
            except curses.error:
                pass
    
    def change_directory(self, new_dir):
        """Change to a new directory"""
        try:
            new_dir = new_dir.resolve()
            if new_dir.exists() and new_dir.is_dir():
                self.current_dir = new_dir
                self.selected_index = 0
                self.scroll_offset = 0
                self.load_directory()
                self.message = ""
            else:
                self.message = "Directory does not exist"
                self.message_color = curses.COLOR_RED
        except Exception as e:
            self.message = f"Error: {e}"
            self.message_color = curses.COLOR_RED
    
    def is_text_file(self, path):
        """Check if a file is likely a text file"""
        # Text file extensions
        text_extensions = {
            '.txt', '.log', '.md', '.markdown', '.rst',
            '.py', '.js', '.jsx', '.ts', '.tsx', '.java', '.c', '.cpp', '.h', '.hpp',
            '.cs', '.php', '.rb', '.go', '.rs', '.swift', '.kt', '.scala',
            '.json', '.xml', '.yaml', '.yml', '.toml', '.ini', '.cfg', '.conf',
            '.html', '.htm', '.css', '.scss', '.sass', '.less',
            '.sh', '.bash', '.zsh', '.fish', '.ps1', '.bat', '.cmd',
            '.sql', '.r', '.m', '.lua', '.pl', '.vim', '.el',
            '.tex', '.bib', '.csv', '.tsv', '.dockerfile', '.makefile',
            '.gitignore', '.gitattributes', '.editorconfig', '.env'
        }
        
        path = Path(path)
        ext = path.suffix.lower()
        
        # Check by extension
        if ext in text_extensions:
            return True
        
        # Check for files without extension that are usually text
        if path.name.lower() in {'readme', 'license', 'makefile', 'dockerfile', 'vagrantfile'}:
            return True
        
        return False
    
    def is_audio_file(self, path):
        """Check if a file is an audio file"""
        audio_extensions = {
            '.mp3', '.flac', '.wav', '.m4a', '.aac', '.ogg', '.opus', 
            '.wma', '.ape', '.alac', '.aiff', '.aif', '.dsf', '.dff'
        }
        
        path = Path(path)
        ext = path.suffix.lower()
        return ext in audio_extensions
    
    def is_video_file(self, path):
        """Check if a file is a video file"""
        video_extensions = {
            '.mp4', '.mkv', '.avi', '.mov', '.wmv', '.flv', '.webm',
            '.m4v', '.mpg', '.mpeg', '.3gp', '.ogv', '.ts', '.m2ts',
            '.vob', '.divx', '.xvid', '.f4v', '.rm', '.rmvb'
        }
        
        path = Path(path)
        ext = path.suffix.lower()
        return ext in video_extensions
    
    def is_image_file(self, path):
        """Check if a file is an image file"""
        image_extensions = {
            '.jpg', '.jpeg', '.png', '.gif', '.bmp', '.tiff', '.tif',
            '.webp', '.svg', '.ico', '.heic', '.heif', '.avif',
            '.raw', '.cr2', '.nef', '.arw', '.dng', '.psd', '.xcf'
        }
        
        path = Path(path)
        ext = path.suffix.lower()
        return ext in image_extensions
    
    def is_iso_file(self, path):
        """Check if a file is an ISO file (Xbox 360/Xbox disc image)"""
        iso_extensions = {'.iso'}
        
        path = Path(path)
        ext = path.suffix.lower()
        return ext in iso_extensions
    
    def handle_enter(self):
        """Handle Enter key - open directory or file"""
        if not self.entries or self.selected_index >= len(self.entries):
            return
        
        entry = self.entries[self.selected_index]
        
        if entry['is_dir']:
            self.change_directory(entry['path'])
        else:
            # Check file type and open appropriate viewer/editor
            if self.is_audio_file(entry['path']):
                # Open audio inspector
                inspector = AudioInspector(self.stdscr, entry['path'], self)
                inspector.run()
                # Reload directory after inspection
                self.load_directory()
            elif self.is_video_file(entry['path']):
                # Open video inspector
                inspector = VideoInspector(self.stdscr, entry['path'], self)
                inspector.run()
                # Reload directory after inspection
                self.load_directory()
            elif self.is_image_file(entry['path']):
                # Open image inspector
                inspector = ImageInspector(self.stdscr, entry['path'], self)
                inspector.run()
                # Reload directory after inspection
                self.load_directory()
            elif self.is_text_file(entry['path']):
                # Open in text editor
                editor = TextEditor(self.stdscr, entry['path'])
                editor.run()
                # Reload directory after editing
                self.load_directory()
            else:
                # For non-text files, show info
                self.message = f"File: {entry['name']} ({self.get_size_string(entry['size'])})"
                self.message_color = curses.COLOR_GREEN
    
    def show_bookmarks_menu(self):
        """Show bookmarks menu"""
        self._enter_blocking_mode()
        bookmarks = self.config.get_bookmarks()
        
        menu_items = []
        menu_items.append(f"{ICONS['bookmark']}  Add current directory as bookmark")
        
        if bookmarks:
            menu_items.append("─" * 40)
            for name, path in bookmarks.items():
                menu_items.append(f"{ICONS['folder_closed']}  {name}: {path}")
            menu_items.append("─" * 40)
            menu_items.append(f"{ICONS['trash']}  Remove a bookmark")
        
        menu_items.append(f"{ICONS['cross']}  Cancel")
        
        selected = 0
        
        while True:
            self.stdscr.clear()
            height, width = self.stdscr.getmaxyx()
            
            # Title
            if self.has_256_colors:
                title = f"  {ICONS['bookmark']}  BOOKMARKS  "
                self.stdscr.addstr(0, 0, " " * width, curses.color_pair(15))
                title_x = (width - len(title)) // 2
                self.stdscr.addstr(0, title_x, title, curses.color_pair(17) | curses.A_BOLD)
            else:
                title = " BOOKMARKS "
                self.stdscr.attron(curses.color_pair(7) | curses.A_BOLD)
                self.stdscr.addstr(0, 0, title.center(width)[:width])
                self.stdscr.attroff(curses.color_pair(7) | curses.A_BOLD)
            
            hint_color = curses.color_pair(14) if self.has_256_colors else curses.color_pair(11)
            self.stdscr.addstr(2, 2, "Use ↑/↓ to navigate, Enter to select", hint_color)
            sep = ICONS['box_h'] * width
            self.stdscr.addstr(3, 0, sep[:width], curses.color_pair(14) if self.has_256_colors else 0)
            
            # Menu items
            start_y = 4
            for i, item in enumerate(menu_items):
                if i + start_y >= height - 2:
                    break
                
                if item.startswith("─"):
                    self.stdscr.addstr(i + start_y, 2, item[:width-4], curses.color_pair(14) if self.has_256_colors else 0)
                elif i == selected:
                    self.stdscr.attron(curses.color_pair(7) | curses.A_BOLD)
                    self.stdscr.addstr(i + start_y, 0, " " * width)
                    self.stdscr.addstr(i + start_y, 2, f"{ICONS['arrow_right']} {item}"[:width-4])
                    self.stdscr.attroff(curses.color_pair(7) | curses.A_BOLD)
                else:
                    self.stdscr.addstr(i + start_y, 2, f"  {item}"[:width-4], curses.color_pair(19) if self.has_256_colors else 0)
            
            self.stdscr.refresh()
            
            # Handle input
            key = self.stdscr.getch()
            
            if key == curses.KEY_UP:
                selected = max(0, selected - 1)
                # Skip separator lines
                while selected < len(menu_items) and menu_items[selected].startswith("─"):
                    selected = max(0, selected - 1)
            elif key == curses.KEY_DOWN:
                selected = min(len(menu_items) - 1, selected + 1)
                # Skip separator lines
                while selected < len(menu_items) and menu_items[selected].startswith("─"):
                    selected = min(len(menu_items) - 1, selected + 1)
            elif key in [ord('\n'), curses.KEY_ENTER, 10, 13]:
                selected_item = menu_items[selected]
                
                if selected_item == "Cancel":
                    break
                elif selected_item == "Add current directory as bookmark":
                    name = self.get_text_input("Enter bookmark name: ")
                    if name:
                        self.config.add_bookmark(name, self.current_dir)
                        self.message = f"Bookmark '{name}' added"
                        self.message_color = curses.COLOR_GREEN
                    break
                elif selected_item == "Remove a bookmark":
                    if bookmarks:
                        name = self.get_text_input("Enter bookmark name to remove: ")
                        if name and name in bookmarks:
                            self.config.remove_bookmark(name)
                            self.message = f"Bookmark '{name}' removed"
                            self.message_color = curses.COLOR_GREEN
                        elif name:
                            self.message = f"Bookmark '{name}' not found"
                            self.message_color = curses.COLOR_RED
                    break
                elif ": " in selected_item:
                    # Navigate to bookmark
                    name, path = selected_item.split(": ", 1)
                    self.change_directory(Path(path))
                    break
            elif key == 27:  # ESC
                break
        self._restore_halfdelay()
    
    def get_text_input(self, prompt):
        """Get text input from user"""
        height, width = self.stdscr.getmaxyx()
        
        # Show input box
        curses.curs_set(1)
        curses.echo()
        
        self.stdscr.addstr(height - 2, 1, " " * (width - 2))
        self.stdscr.addstr(height - 2, 1, prompt, curses.color_pair(11) | curses.A_BOLD)
        self.stdscr.refresh()
        
        # Get input
        input_str = self.stdscr.getstr(height - 2, 1 + len(prompt), width - len(prompt) - 3).decode('utf-8')
        
        curses.noecho()
        curses.curs_set(0)
        
        return input_str.strip()

    def _execute_palette_action(self, action):
        """Dispatch a command-palette action to existing handlers."""
        if action == 'copy':
            self.copy_to_clipboard()
        elif action == 'cut':
            self.cut_to_clipboard()
        elif action == 'paste':
            self.paste_from_clipboard()
        elif action == 'delete':
            self.delete_files()
        elif action == 'new':
            self.create_new()
        elif action == 'rename':
            self.rename_item()
        elif action == 'bookmarks':
            self.show_bookmarks_menu()
        elif action == 'tools':
            self.show_tools_menu()
        elif action == 'permissions':
            self.fix_permissions()
        elif action == 'find_empty':
            self.find_empty_folders()
        elif action == 'extract':
            self.extract_archives()
        elif action == 'help':
            self.show_help = not self.show_help
        elif action == 'quit':
            self.running = False

    def show_command_palette(self, mode='command'):
        """Show VS Code-style command/search palette."""
        self._enter_blocking_mode()
        height, width = self.stdscr.getmaxyx()
        palette_width = min(width - 8, 60)
        if palette_width < 20:
            return

        start_y = 4
        start_x = (width - palette_width) // 2
        max_visible_items = 12

        query = ""
        selected = 0
        scroll = 0

        try:
            curses.curs_set(1)
        except curses.error:
            pass

        try:
            while True:
                if mode == 'command':
                    q = query.lower().strip()
                    filtered = [cmd for cmd in PALETTE_COMMANDS if q in cmd['label'].lower()]
                else:
                    q = query.lower().strip()
                    filtered = [e for e in self.entries if q in e['name'].lower()]

                if selected >= len(filtered):
                    selected = max(0, len(filtered) - 1)

                visible_items = min(max_visible_items, max(1, len(filtered)))
                palette_height = visible_items + 4

                if selected < scroll:
                    scroll = selected
                elif selected >= scroll + visible_items:
                    scroll = selected - visible_items + 1
                scroll = max(0, scroll)

                # Dim the full background first.
                if self.use_true_color:
                    for y in range(height):
                        tc_addstr(self.stdscr, y, 0, ' ' * width, bg=THEME['shadow'])
                else:
                    dim_attr = curses.color_pair(44) if self.has_256_colors else curses.A_DIM
                    for y in range(height):
                        try:
                            self.stdscr.addstr(y, 0, ' ' * width, dim_attr)
                        except curses.error:
                            pass

                if self.use_true_color:
                    for dy in range(palette_height):
                        tc_addstr(self.stdscr, start_y + dy, start_x, ' ' * palette_width, bg=THEME['bg_overlay'])
                else:
                    body = curses.color_pair(40) if self.has_256_colors else curses.color_pair(7)
                    for dy in range(palette_height):
                        try:
                            self.stdscr.addstr(start_y + dy, start_x, ' ' * palette_width, body)
                        except curses.error:
                            pass

                # Border
                top = ICONS['box_tl'] + ICONS['box_h'] * (palette_width - 2) + ICONS['box_tr']
                bot = ICONS['box_bl'] + ICONS['box_h'] * (palette_width - 2) + ICONS['box_br']
                sep = ICONS['box_t_right'] + ICONS['box_h'] * (palette_width - 2) + ICONS['box_t_left']

                if self.use_true_color:
                    tc_addstr(self.stdscr, start_y, start_x, top, fg=THEME['border_accent'], bg=THEME['bg_overlay'])
                    tc_addstr(self.stdscr, start_y + palette_height - 1, start_x, bot, fg=THEME['border_accent'], bg=THEME['bg_overlay'])
                    tc_addstr(self.stdscr, start_y + 2, start_x, sep, fg=THEME['border_accent'], bg=THEME['bg_overlay'])
                    for dy in range(1, palette_height - 1):
                        tc_addstr(self.stdscr, start_y + dy, start_x, ICONS['box_v'], fg=THEME['border_accent'], bg=THEME['bg_overlay'])
                        tc_addstr(self.stdscr, start_y + dy, start_x + palette_width - 1, ICONS['box_v'], fg=THEME['border_accent'], bg=THEME['bg_overlay'])
                else:
                    border = curses.color_pair(43) if self.has_256_colors else curses.color_pair(7)
                    try:
                        self.stdscr.addstr(start_y, start_x, top, border)
                        self.stdscr.addstr(start_y + palette_height - 1, start_x, bot, border)
                        self.stdscr.addstr(start_y + 2, start_x, sep, border)
                    except curses.error:
                        pass
                    for dy in range(1, palette_height - 1):
                        try:
                            self.stdscr.addstr(start_y + dy, start_x, ICONS['box_v'], border)
                            self.stdscr.addstr(start_y + dy, start_x + palette_width - 1, ICONS['box_v'], border)
                        except curses.error:
                            pass

                prompt_icon = ICONS['search'] if mode == 'search' else ':'
                placeholder = 'Type to search...' if mode == 'search' else 'Type a command...'
                query_text = query if query else placeholder
                input_line = f"  {prompt_icon}  {query_text}"

                if self.use_true_color:
                    tc_addstr(
                        self.stdscr,
                        start_y + 1,
                        start_x + 1,
                        input_line[:palette_width - 2].ljust(palette_width - 2),
                        fg=THEME['text_primary'] if query else THEME['text_dim'],
                        bg=THEME['bg_overlay'],
                    )
                else:
                    attr = (curses.color_pair(11) if self.has_256_colors else curses.A_BOLD)
                    try:
                        self.stdscr.addstr(start_y + 1, start_x + 1, input_line[:palette_width - 2].ljust(palette_width - 2), attr)
                    except curses.error:
                        pass

                list_y = start_y + 3
                if not filtered:
                    msg = 'No results'
                    if self.use_true_color:
                        tc_addstr(self.stdscr, list_y, start_x + 2, msg[:palette_width - 4], fg=THEME['text_dim'], bg=THEME['bg_overlay'])
                    else:
                        try:
                            self.stdscr.addstr(list_y, start_x + 2, msg[:palette_width - 4], curses.color_pair(14))
                        except curses.error:
                            pass
                else:
                    visible_slice = filtered[scroll:scroll + visible_items]
                    for i, item in enumerate(visible_slice):
                        row_y = list_y + i
                        is_selected = (scroll + i) == selected

                        if mode == 'command':
                            item_icon = item['icon'] or ' '
                            key_badge = item['key']
                            label = item['label']
                            prefix = '► ' if is_selected else '  '
                            text = f"{prefix}{item_icon}  {label}"
                        else:
                            item_icon = self.get_file_icon(item) or ' '
                            key_badge = ''
                            prefix = '► ' if is_selected else '  '
                            text = f"{prefix}{item_icon}  {item['name']}"

                        if self.use_true_color:
                            bg = THEME['bg_selection_accent'] if is_selected else THEME['bg_overlay']
                            fg = THEME['text_primary'] if is_selected else THEME['text_secondary']
                            tc_addstr(self.stdscr, row_y, start_x + 1, text[:palette_width - 2].ljust(palette_width - 2), fg=fg, bg=bg, bold=is_selected)
                            if key_badge:
                                key_x = start_x + palette_width - len(key_badge) - 3
                                tc_addstr(self.stdscr, row_y, key_x, key_badge, fg=THEME['text_dim'], bg=bg)
                        else:
                            attr = (curses.color_pair(7) | curses.A_BOLD) if is_selected else curses.color_pair(14)
                            try:
                                self.stdscr.addstr(row_y, start_x + 1, text[:palette_width - 2].ljust(palette_width - 2), attr)
                                if key_badge:
                                    key_x = start_x + palette_width - len(key_badge) - 3
                                    self.stdscr.addstr(row_y, key_x, key_badge, curses.color_pair(14))
                            except curses.error:
                                pass

                cursor_x = min(start_x + palette_width - 3, start_x + 5 + len(query))
                try:
                    self.stdscr.move(start_y + 1, cursor_x)
                except curses.error:
                    pass

                self.stdscr.refresh()
                key = self.stdscr.getch()

                if key in [27]:
                    break
                if key in [ord('\n'), curses.KEY_ENTER, 10, 13]:
                    if not filtered:
                        continue
                    picked = filtered[selected]
                    if mode == 'command':
                        self._execute_palette_action(picked['action'])
                    else:
                        target_path = picked['path']
                        for idx, entry in enumerate(self.entries):
                            if entry['path'] == target_path:
                                self.selected_index = idx
                                break
                    break
                if key in [curses.KEY_UP]:
                    selected = max(0, selected - 1)
                    continue
                if key in [curses.KEY_DOWN]:
                    selected = min(max(0, len(filtered) - 1), selected + 1)
                    continue
                if key in [curses.KEY_BACKSPACE, 127, 8]:
                    query = query[:-1]
                    continue
                if 32 <= key <= 126:
                    query += chr(key)
        finally:
            try:
                curses.curs_set(0)
            except curses.error:
                pass
            self._restore_halfdelay()
            self.draw()
    
